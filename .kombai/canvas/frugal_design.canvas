      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --primary: #FF500B;\n        --bg-deep: oklch(0.06 0.025 270);\n        --text-crisp: oklch(0.97 0 0);\n    }\n\n    body {\n        margin: 0;\n        padding: 0;\n        background-color: var(--bg-deep);\n        color: var(--text-crisp);\n        font-family: 'Inter', sans-serif;\n    }\n\n    .mesh-gradient {\n        background: radial-gradient(at 10% 10%, var(--bg-deep) 0%, transparent 60%),\n                    radial-gradient(at 90% 10%, rgba(255, 80, 11, 0.15) 0%, transparent 60%),\n                    radial-gradient(at 90% 90%, var(--bg-deep) 0%, transparent 60%),\n                    radial-gradient(at 10% 90%, rgba(147, 51, 234, 0.1) 0%, transparent 60%);\n    }\n\n    .glass-panel {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(24px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);\n    }\n\n    .input-field {\n        background: rgba(255, 255, 255, 0.04);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n        transition: all 0.2s ease;\n    }\n\n    .input-field:focus {\n        border-color: var(--primary);\n        background: rgba(255, 255, 255, 0.06);\n        outline: none;\n        box-shadow: 0 0 0 2px rgba(255, 80, 11, 0.2);\n    }\n\n    .primary-btn {\n        background: var(--primary);\n        box-shadow: 0 10px 25px -5px rgba(255, 80, 11, 0.4);\n        transition: all 0.2s ease;\n    }\n\n    .primary-btn:hover {\n        box-shadow: 0 15px 30px -5px rgba(255, 80, 11, 0.6);\n        transform: translateY(-1px);\n    }\n\n    /* Modal Checkbox Hack */\n    #modal-toggle:checked ~ #modal-overlay {\n        display: flex;\n        opacity: 1;\n        pointer-events: auto;\n    }\n\n    #modal-overlay {\n        display: none;\n        opacity: 0;\n        transition: opacity 0.3s ease;\n        z-index: 100;\n    }\n\n    .sidebar-link.active {\n        background: linear-gradient(90deg, rgba(255, 80, 11, 0.12) 0%, transparent 100%);\n        color: var(--primary);\n        position: relative;\n    }\n\n    .sidebar-link.active::before {\n        content: '';\n        position: absolute;\n        left: 0;\n        top: 20%;\n        height: 60%;\n        width: 3px;\n        background: var(--primary);\n        border-radius: 0 4px 4px 0;\n        box-shadow: 0 0 10px var(--primary);\n    }\n\n    @keyframes float {\n        0%, 100% { transform: translateY(0); }\n        50% { transform: translateY(-10px); }\n    }\n    .animate-float { animation: float 5s ease-in-out infinite; }\n</style>\n\n<div class=\"flex min-h-[950px] w-full relative overflow-hidden bg-[var(--bg-deep)]\" data-kid=\"1\">\n    \n    <div class=\"absolute inset-0 mesh-gradient pointer-events-none opacity-40\" data-kid=\"2\"></div>\n    <div class=\"absolute -top-40 -right-40 w-96 h-96 bg-[var(--primary)]/10 blur-[120px] rounded-full animate-pulse\" data-kid=\"3\"></div>\n    \n    \n    <aside class=\"w-72 border-r border-white/5 flex flex-col z-20 backdrop-blur-xl bg-[var(--bg-deep)]/40\" data-kid=\"4\">\n        <div class=\"p-8\" data-kid=\"5\">\n            <div class=\"flex items-center gap-3 mb-12\" data-kid=\"6\">\n                <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#FF500B]/20 to-[#FF500B]/5 flex items-center justify-center border border-[#FF500B]/30\" data-kid=\"7\">\n                    <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"8\"></i>\n                </div>\n                <span class=\"text-xl font-bold tracking-[0.05em] text-white uppercase\" data-kid=\"9\">Frugal</span>\n            </div>\n\n            <nav class=\"space-y-2\" data-kid=\"10\">\n                <a href=\"#\" class=\"flex items-center gap-4 px-6 py-4 rounded-2xl text-white/40 hover:text-white hover:bg-white/5 transition-all group\" data-kid=\"11\">\n                    <i class=\"ti ti-smart-home text-xl\" data-kid=\"12\"></i>\n                    <span class=\"font-semibold tracking-tight\" data-kid=\"13\">Overview</span>\n                </a>\n                <a href=\"#\" class=\"flex items-center gap-4 px-6 py-4 rounded-2xl text-white/40 hover:text-white hover:bg-white/5 transition-all group\" data-kid=\"14\">\n                    <i class=\"ti ti-box text-xl\" data-kid=\"15\"></i>\n                    <span class=\"font-semibold tracking-tight\" data-kid=\"16\">Projects</span>\n                </a>\n                <a href=\"#\" class=\"sidebar-link active flex items-center gap-4 px-6 py-4 rounded-2xl transition-all group\" data-kid=\"17\">\n                    <i class=\"ti ti-shield-lock text-xl\" data-kid=\"18\"></i>\n                    <span class=\"font-semibold tracking-tight\" data-kid=\"19\">Budget Rules</span>\n                </a>\n                <a href=\"#\" class=\"flex items-center gap-4 px-6 py-4 rounded-2xl text-white/40 hover:text-white hover:bg-white/5 transition-all group\" data-kid=\"20\">\n                    <i class=\"ti ti-chart-bar text-xl\" data-kid=\"21\"></i>\n                    <span class=\"font-semibold tracking-tight\" data-kid=\"22\">Analytics</span>\n                </a>\n                <a href=\"#\" class=\"flex items-center gap-4 px-6 py-4 rounded-2xl text-white/40 hover:text-white hover:bg-white/5 transition-all group\" data-kid=\"23\">\n                    <i class=\"ti ti-wallet text-xl\" data-kid=\"24\"></i>\n                    <span class=\"font-semibold tracking-tight\" data-kid=\"25\">Billing</span>\n                </a>\n            </nav>\n        </div>\n\n        <div class=\"mt-auto p-8 border-t border-white/5\" data-kid=\"26\">\n            <div class=\"flex items-center gap-4\" data-kid=\"27\">\n                <img src=\"https://i.pravatar.cc/100?u=alex\" alt=\"User\" class=\"w-10 h-10 rounded-full border border-white/10\" decoding=\"async\" loading=\"lazy\" data-kid=\"28\">\n                <div class=\"flex-1 min-w-0\" data-kid=\"29\">\n                    <p class=\"text-sm font-bold text-white truncate\" data-kid=\"30\">Alex Rivera</p>\n                    <p class=\"text-xs text-white/40 truncate\" data-kid=\"31\">Admin Space</p>\n                </div>\n                <button class=\"text-white/20 hover:text-white transition-colors\" data-kid=\"32\">\n                    <i class=\"ti ti-logout text-lg\" data-kid=\"33\"></i>\n                </button>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 p-12 z-10 overflow-y-auto relative\" data-kid=\"34\">\n        \n        <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;\" data-kid=\"35\">\n        </div>\n        <header class=\"flex justify-between items-end mb-16 relative z-10\" data-kid=\"36\">\n            <div class=\"space-y-4\" data-kid=\"37\">\n                <div class=\"flex items-center gap-2 text-[var(--primary)] text-xs font-black tracking-[0.25em] uppercase\" data-kid=\"38\">\n                    <span class=\"relative flex h-2 w-2\" data-kid=\"39\">\n                        <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--primary)] opacity-75\" data-kid=\"40\"></span>\n                        <span class=\"relative inline-flex rounded-full h-2 w-2 bg-[var(--primary)]\" data-kid=\"41\"></span>\n                    </span>\n                    System Protection: Active\n                </div>\n                <h1 class=\"text-7xl font-['Instrument_Serif'] italic tracking-tight text-white leading-none\" data-kid=\"42\">Budget Rules</h1>\n                <p class=\"text-white/50 text-xl max-w-xl font-medium leading-relaxed\" data-kid=\"43\">Automated governance for high-scale infrastructure. Prevent overruns before they happen.</p>\n            </div>\n\n            \n            <label for=\"modal-toggle\" class=\"primary-btn px-8 py-5 rounded-2xl text-white font-bold text-lg cursor-pointer flex items-center gap-4 active:scale-95 transition-all group border border-white/10\" data-kid=\"44\">\n                <div class=\"w-6 h-6 rounded-lg bg-white/20 flex items-center justify-center group-hover:rotate-90 transition-transform duration-500\" data-kid=\"45\">\n                    <i class=\"ti ti-plus text-white text-sm\" data-kid=\"46\"></i>\n                </div>\n                Add Enforcer Rule\n            </label>\n        </header>\n\n        \n        <div class=\"grid grid-cols-3 gap-6 mb-12\" data-kid=\"47\">\n            <div class=\"glass-panel p-8 rounded-3xl space-y-4 hover:border-white/20 transition-all group\" data-kid=\"48\">\n                <div class=\"flex items-center justify-between\" data-kid=\"49\">\n                    <span class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.3em]\" data-kid=\"50\">Active Shields</span>\n                    <div class=\"w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center\" data-kid=\"51\"><i class=\"ti ti-shield-check text-emerald-400\" data-kid=\"52\"></i></div>\n                </div>\n                <p class=\"text-4xl font-bold text-white group-hover:translate-x-1 transition-transform tracking-tight\" data-kid=\"53\">12 <span class=\"text-sm font-medium text-white/40 ml-1\" data-kid=\"54\">Rules</span></p>\n            </div>\n            <div class=\"glass-panel p-8 rounded-3xl space-y-4 hover:border-white/20 transition-all group\" data-kid=\"55\">\n                <div class=\"flex items-center justify-between\" data-kid=\"56\">\n                    <span class=\"text-[10px] font-black text-white/30 uppercase tracking-[0.3em]\" data-kid=\"57\">Spend Stopped</span>\n                    <div class=\"w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center\" data-kid=\"58\"><i class=\"ti ti-coin-off text-amber-400\" data-kid=\"59\"></i></div>\n                </div>\n                <p class=\"text-4xl font-bold text-white group-hover:translate-x-1 transition-transform tracking-tight\" data-kid=\"60\">$14.2k <span class=\"text-sm font-medium text-white/40 ml-1\" data-kid=\"61\">Saved</span></p>\n            </div>\n            <div class=\"glass-panel p-8 rounded-3xl space-y-4 border-[var(--primary)]/30 bg-linear-to-br from-[var(--primary)]/5 to-transparent hover:border-[var(--primary)]/50 transition-all group\" data-kid=\"62\">\n                <div class=\"flex items-center justify-between\" data-kid=\"63\">\n                    <span class=\"text-[10px] font-black text-[var(--primary)] uppercase tracking-[0.3em]\" data-kid=\"64\">Protection Level</span>\n                    <div class=\"w-8 h-8 rounded-lg bg-[var(--primary)]/10 flex items-center justify-center\" data-kid=\"65\"><i class=\"ti ti-bolt text-[var(--primary)]\" data-kid=\"66\"></i></div>\n                </div>\n                <p class=\"text-4xl font-bold text-white group-hover:translate-x-1 transition-transform tracking-tight\" data-kid=\"67\">99.2%</p>\n            </div>\n        </div>\n\n        \n        <div class=\"glass-panel rounded-[40px] overflow-hidden\" data-kid=\"68\">\n            <div class=\"px-8 py-6 border-b border-white/10 flex justify-between items-center bg-white/2\" data-kid=\"69\">\n                <h3 class=\"text-xl font-semibold text-white\" data-kid=\"70\">Active Enforcement Rules</h3>\n                <div class=\"flex gap-4\" data-kid=\"71\">\n                    <div class=\"relative\" data-kid=\"72\">\n                        <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-white/30\" data-kid=\"73\"></i>\n                        <input type=\"text\" placeholder=\"Filter by project...\" class=\"pl-11 pr-6 py-2 rounded-xl bg-white/5 border border-white/10 text-sm text-white focus:outline-hidden focus:border-white/20\" data-kid=\"74\">\n                    </div>\n                </div>\n            </div>\n            \n            <table class=\"w-full text-left border-collapse table-fixed\" data-kid=\"75\">\n                <thead data-kid=\"76\">\n                    <tr class=\"bg-white/2\" data-kid=\"77\">\n                        <th class=\"w-[30%] px-10 py-6 text-[11px] font-black uppercase tracking-[0.3em] text-white/40 border-b border-white/5\" data-kid=\"78\">Project & Identifier</th>\n                        <th class=\"w-[20%] px-10 py-6 text-[11px] font-black uppercase tracking-[0.3em] text-white/40 border-b border-white/5\" data-kid=\"79\">Limit Per Month</th>\n                        <th class=\"w-[20%] px-10 py-6 text-[11px] font-black uppercase tracking-[0.3em] text-white/40 border-b border-white/5\" data-kid=\"80\">Alert Threshold</th>\n                        <th class=\"w-[18%] px-10 py-6 text-[11px] font-black uppercase tracking-[0.3em] text-white/40 border-b border-white/5\" data-kid=\"81\">Action Policy</th>\n                        <th class=\"w-[12%] px-10 py-6 text-[11px] font-black uppercase tracking-[0.3em] text-white/40 border-b border-white/5 text-right\" data-kid=\"82\">Activity</th>\n                    </tr>\n                </thead>\n                <tbody class=\"divide-y divide-white/5\" data-kid=\"83\">\n                    \n                    <tr class=\"hover:bg-white/5 transition-all group\" data-kid=\"84\">\n                        <td class=\"px-10 py-7\" data-kid=\"85\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"86\">\n                                <div class=\"w-12 h-12 rounded-2xl bg-indigo-500/10 flex items-center justify-center border border-indigo-500/20 group-hover:scale-110 transition-transform\" data-kid=\"87\">\n                                    <i class=\"ti ti-server text-indigo-400 text-xl\" data-kid=\"88\"></i>\n                                </div>\n                                <div data-kid=\"89\">\n                                    <p class=\"font-bold text-white text-base\" data-kid=\"90\">Core Infra Alpha</p>\n                                    <p class=\"text-xs text-white/30 font-mono tracking-tighter\" data-kid=\"91\">PRJ_772_AWS_EAST</p>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"92\">\n                            <p class=\"text-lg font-bold text-white\" data-kid=\"93\">$4,500.00</p>\n                            <p class=\"text-xs text-white/30 italic\" data-kid=\"94\">Renewal: June 12</p>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"95\">\n                            <div class=\"space-y-2\" data-kid=\"96\">\n                                <div class=\"flex justify-between items-end text-xs mb-1\" data-kid=\"97\">\n                                    <span class=\"font-bold text-white/60\" data-kid=\"98\">80%</span>\n                                    <span class=\"text-white/20\" data-kid=\"99\">Shield Active</span>\n                                </div>\n                                <div class=\"w-full h-2 bg-white/5 rounded-full overflow-hidden\" data-kid=\"100\">\n                                    <div class=\"h-full bg-indigo-500 rounded-full\" style=\"width: 80%\" data-kid=\"101\"></div>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"102\">\n                            <span class=\"px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-[10px] font-black uppercase tracking-widest whitespace-nowrap\" data-kid=\"103\">Throttle Only</span>\n                        </td>\n                        <td class=\"px-10 py-7 text-right\" data-kid=\"104\">\n                            <div class=\"flex justify-end gap-3 opacity-30 group-hover:opacity-100 transition-all translate-x-2 group-hover:translate-x-0\" data-kid=\"105\">\n                                <button class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 text-white/60 hover:text-white transition-all\" data-kid=\"106\"><i class=\"ti ti-edit\" data-kid=\"107\"></i></button>\n                                <button class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-red-500/10 text-white/60 hover:text-red-400 transition-all\" data-kid=\"108\"><i class=\"ti ti-trash\" data-kid=\"109\"></i></button>\n                            </div>\n                        </td>\n                    </tr>\n                    \n                    <tr class=\"hover:bg-white/5 transition-all group\" data-kid=\"110\">\n                        <td class=\"px-10 py-7\" data-kid=\"111\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"112\">\n                                <div class=\"w-12 h-12 rounded-2xl bg-[var(--primary)]/10 flex items-center justify-center border border-[var(--primary)]/20 group-hover:scale-110 transition-transform\" data-kid=\"113\">\n                                    <i class=\"ti ti-api text-[var(--primary)] text-xl\" data-kid=\"114\"></i>\n                                </div>\n                                <div data-kid=\"115\">\n                                    <p class=\"font-bold text-white text-base\" data-kid=\"116\">Payment Gateway v2</p>\n                                    <p class=\"text-xs text-white/30 font-mono tracking-tighter\" data-kid=\"117\">PRJ_104_STRIPE_INT</p>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"118\">\n                            <p class=\"text-lg font-bold text-white\" data-kid=\"119\">$12,000.00</p>\n                            <p class=\"text-xs text-white/30 italic\" data-kid=\"120\">Renewal: June 01</p>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"121\">\n                            <div class=\"space-y-2\" data-kid=\"122\">\n                                <div class=\"flex justify-between items-end text-xs mb-1\" data-kid=\"123\">\n                                    <span class=\"font-bold text-[var(--primary)]\" data-kid=\"124\">95%</span>\n                                    <span class=\"text-red-400 font-bold animate-pulse\" data-kid=\"125\">Critical</span>\n                                </div>\n                                <div class=\"w-full h-2 bg-white/5 rounded-full overflow-hidden\" data-kid=\"126\">\n                                    <div class=\"h-full bg-[var(--primary)] rounded-full\" style=\"width: 95%\" data-kid=\"127\"></div>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"128\">\n                            <span class=\"px-4 py-1.5 rounded-full bg-red-500/10 border border-red-500/20 text-red-400 text-[10px] font-black uppercase tracking-widest whitespace-nowrap shadow-[0_0_15px_rgba(239,68,68,0.2)]\" data-kid=\"129\">Kill Instance</span>\n                        </td>\n                        <td class=\"px-10 py-7 text-right\" data-kid=\"130\">\n                            <div class=\"flex justify-end gap-3 opacity-30 group-hover:opacity-100 transition-all translate-x-2 group-hover:translate-x-0\" data-kid=\"131\">\n                                <button class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 text-white/60 hover:text-white transition-all\" data-kid=\"132\"><i class=\"ti ti-edit\" data-kid=\"133\"></i></button>\n                                <button class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-red-500/10 text-white/60 hover:text-red-400 transition-all\" data-kid=\"134\"><i class=\"ti ti-trash\" data-kid=\"135\"></i></button>\n                            </div>\n                        </td>\n                    </tr>\n                    \n                    <tr class=\"hover:bg-white/5 transition-all group\" data-kid=\"136\">\n                        <td class=\"px-10 py-7\" data-kid=\"137\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"138\">\n                                <div class=\"w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center border border-emerald-500/20 group-hover:scale-110 transition-transform\" data-kid=\"139\">\n                                    <i class=\"ti ti-database text-emerald-400 text-xl\" data-kid=\"140\"></i>\n                                </div>\n                                <div data-kid=\"141\">\n                                    <p class=\"font-bold text-white text-base\" data-kid=\"142\">Analytic Lake</p>\n                                    <p class=\"text-xs text-white/30 font-mono tracking-tighter\" data-kid=\"143\">PRJ_882_SNOWFLAKE</p>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"144\">\n                            <p class=\"text-lg font-bold text-white\" data-kid=\"145\">$800.00</p>\n                            <p class=\"text-xs text-white/30 italic\" data-kid=\"146\">Renewal: June 20</p>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"147\">\n                            <div class=\"space-y-2\" data-kid=\"148\">\n                                <div class=\"flex justify-between items-end text-xs mb-1\" data-kid=\"149\">\n                                    <span class=\"font-bold text-emerald-400\" data-kid=\"150\">12%</span>\n                                    <span class=\"text-white/20\" data-kid=\"151\">Safe Zone</span>\n                                </div>\n                                <div class=\"w-full h-2 bg-white/5 rounded-full overflow-hidden\" data-kid=\"152\">\n                                    <div class=\"h-full bg-emerald-500 rounded-full\" style=\"width: 12%\" data-kid=\"153\"></div>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"154\">\n                            <span class=\"px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/40 text-[10px] font-black uppercase tracking-widest whitespace-nowrap\" data-kid=\"155\">Slack Alert</span>\n                        </td>\n                        <td class=\"px-10 py-7 text-right\" data-kid=\"156\">\n                            <div class=\"flex justify-end gap-3 opacity-30 group-hover:opacity-100 transition-all translate-x-2 group-hover:translate-x-0\" data-kid=\"157\">\n                                <button class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 text-white/60 hover:text-white transition-all\" data-kid=\"158\"><i class=\"ti ti-edit\" data-kid=\"159\"></i></button>\n                                <button class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-red-500/10 text-white/60 hover:text-red-400 transition-all\" data-kid=\"160\"><i class=\"ti ti-trash\" data-kid=\"161\"></i></button>\n                            </div>\n                        </td>\n                    </tr>\n                    \n                    <tr class=\"hover:bg-white/5 transition-all group\" data-kid=\"162\">\n                        <td class=\"px-10 py-7\" data-kid=\"163\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"164\">\n                                <div class=\"w-12 h-12 rounded-2xl bg-orange-500/10 flex items-center justify-center border border-orange-500/20 group-hover:scale-110 transition-transform\" data-kid=\"165\">\n                                    <i class=\"ti ti-building-broadcast-tower text-orange-400 text-xl\" data-kid=\"166\"></i>\n                                </div>\n                                <div data-kid=\"167\">\n                                    <p class=\"font-bold text-white text-base\" data-kid=\"168\">Edge CDN Global</p>\n                                    <p class=\"text-xs text-white/30 font-mono tracking-tighter\" data-kid=\"169\">PRJ_992_CLOUDFLARE</p>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"170\">\n                            <p class=\"text-lg font-bold text-white\" data-kid=\"171\">$2,200.00</p>\n                            <p class=\"text-xs text-white/30 italic\" data-kid=\"172\">Renewal: June 05</p>\n                        </td>\n                        <td class=\"px-10 py-7\" data-kid=\"173\">\n                            <div class=\"space-y-2\" data-kid=\"174\">\n                                <div class=\"flex justify-between items-end text-xs mb-1\" data-kid=\"175\">\n                                    <span class=\"font-bold text-orange-400\" data-kid=\"176\">45%</span>\n                                    <span class=\"text-white/20\" data-kid=\"177\">Active</span>\n                                </div>\n                                <div class=\"w-full h-2 bg-white/5 rounded-full overflow-hidden\" data-kid=\"178\">\n                                    <div class=\"h-full bg-orange-500 rounded-full\" style=\"width: 45%\" data-kid=\"179\"></div>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"px-10 py-7\"