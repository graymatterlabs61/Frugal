      "html": "\n<main class=\"w-full min-h-[900px] flex overflow-hidden bg-[oklch(0.06_0.025_270)] selection:bg-[#FF500B]/30 font-sans text-white\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --primary: #FF500B;\n            --bg-deep: oklch(0.06 0.025 270);\n            --text-crisp: oklch(0.97 0 0);\n        }\n\n        .font-serif { font-family: 'Instrument Serif', serif; }\n        .font-sans { font-family: 'Inter', sans-serif; }\n\n        .mesh-gradient {\n            background: radial-gradient(at 10% 10%, var(--bg-deep) 0%, transparent 60%),\n                        radial-gradient(at 90% 10%, rgba(255, 80, 11, 0.12) 0%, transparent 60%),\n                        radial-gradient(at 90% 90%, var(--bg-deep) 0%, transparent 60%),\n                        radial-gradient(at 10% 90%, rgba(147, 51, 234, 0.08) 0%, transparent 60%);\n        }\n\n        .mesh-orb {\n            position: absolute;\n            filter: blur(120px);\n            border-radius: 9999px;\n            z-index: 1;\n            opacity: 0.5;\n        }\n\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.03);\n            backdrop-filter: blur(28px);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);\n            transition: all 0.3s ease;\n        }\n\n        .input-field {\n            background: rgba(255, 255, 255, 0.04);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transition: all 0.2s ease;\n        }\n\n        .input-field:focus {\n            border-color: var(--primary);\n            background: rgba(255, 255, 255, 0.06);\n            outline: none;\n            box-shadow: 0 0 0 2px rgba(255, 80, 11, 0.2);\n        }\n\n        .primary-btn {\n            background: var(--primary);\n            box-shadow: 0 10px 25px -5px rgba(255, 80, 11, 0.4);\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .primary-btn:hover {\n            box-shadow: 0 15px 35px -5px rgba(255, 80, 11, 0.6);\n            transform: translateY(-1px);\n        }\n\n        .primary-btn:active {\n            transform: translateY(1px) scale(0.98);\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0) rotate(-1.5deg); }\n            50% { transform: translateY(-20px) rotate(-0.5deg); }\n        }\n\n        .animate-float {\n            animation: float 7s ease-in-out infinite;\n        }\n\n        @keyframes shimmer {\n            0% { transform: translateX(-100%); }\n            100% { transform: translateX(100%); }\n        }\n    </style>\n\n    \n    <section class=\"w-1/2 flex flex-col items-center justify-center p-8 lg:p-16 z-10 bg-[var(--bg-deep)] relative\" data-kid=\"2\">\n        <div class=\"w-full max-w-[420px] space-y-12\" data-kid=\"3\">\n            \n            \n            <div class=\"flex items-center gap-3\" data-kid=\"4\">\n                <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#FF500B]/20 to-[#FF500B]/5 flex items-center justify-center border border-[#FF500B]/30 shadow-[0_0_15px_rgba(255,80,11,0.1)]\" data-kid=\"5\">\n                    <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"6\"></i>\n                </div>\n                <span class=\"text-xl font-bold tracking-[0.05em] text-[var(--text-crisp)] uppercase\" data-kid=\"7\">Frugal</span>\n            </div>\n\n            \n            <div class=\"space-y-4\" data-kid=\"8\">\n                <h1 class=\"text-7xl font-serif italic tracking-tighter leading-[0.85] text-white\" data-kid=\"9\">Reset Password</h1>\n                <p class=\"text-white/60 text-lg max-w-[340px]\" data-kid=\"10\">Enter your email to receive a secure recovery link for your account.</p>\n            </div>\n\n            \n            <form class=\"space-y-8\" onsubmit=\"event.preventDefault()\" data-kid=\"11\">\n                <div class=\"space-y-3\" data-kid=\"12\">\n                    <label for=\"email\" class=\"text-sm font-semibold text-white/90 ml-1 tracking-wide\" data-kid=\"13\">Work Email</label>\n                    <input type=\"email\" id=\"email\" placeholder=\"alex@company.com\" class=\"w-full px-5 py-4.5 rounded-2xl input-field text-white placeholder:text-white/25\" data-kid=\"14\">\n                </div>\n\n                <button type=\"submit\" class=\"w-full py-5 rounded-2xl primary-btn text-white font-bold text-lg cursor-pointer overflow-hidden group relative\" data-kid=\"15\">\n                    <span class=\"relative z-10 flex items-center justify-center gap-2\" data-kid=\"16\">\n                        Send Reset Link\n                        <i class=\"ti ti-arrow-right text-white/50 group-hover:translate-x-1 transition-transform\" data-kid=\"17\"></i>\n                    </span>\n                    <div class=\"absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-[shimmer_2s_infinite]\" data-kid=\"18\"></div>\n                </button>\n            </form>\n\n            \n            <div class=\"pt-4 flex flex-col items-center gap-8\" data-kid=\"19\">\n                <a href=\"#\" class=\"inline-flex items-center gap-2.5 text-white/50 hover:text-white transition-all group font-medium text-sm\" data-kid=\"20\">\n                    <div class=\"w-9 h-9 rounded-full bg-white/5 flex items-center justify-center transition-all group-hover:bg-white/10 group-hover:-translate-x-1 border border-white/5\" data-kid=\"21\">\n                        <i class=\"ti ti-arrow-left text-lg\" data-kid=\"22\"></i>\n                    </div>\n                    Back to login\n                </a>\n                \n                <div class=\"w-full flex items-center gap-4\" data-kid=\"23\">\n                    <div class=\"h-px grow bg-white/5\" data-kid=\"24\"></div>\n                    <span class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-white/20\" data-kid=\"25\">Security Layer</span>\n                    <div class=\"h-px grow bg-white/5\" data-kid=\"26\"></div>\n                </div>\n\n                <div class=\"flex items-center gap-8 opacity-40 grayscale hover:grayscale-0 hover:opacity-80 transition-all duration-500\" data-kid=\"27\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"28\">\n                        <i class=\"ti ti-shield-check text-xl\" data-kid=\"29\"></i>\n                        <span class=\"text-xs font-mono\" data-kid=\"30\">SOC2 Type II</span>\n                    </div>\n                    <div class=\"flex items-center gap-2\" data-kid=\"31\">\n                        <i class=\"ti ti-lock text-xl\" data-kid=\"32\"></i>\n                        <span class=\"text-xs font-mono\" data-kid=\"33\">AES-256</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"w-1/2 relative flex items-center justify-center overflow-hidden bg-[var(--bg-deep)] border-l border-white/5\" data-kid=\"34\">\n        \n        \n        <div class=\"absolute inset-0 z-0\" data-kid=\"35\">\n            <img src=\"https://images.unsplash.com/photo-1635072523063-d56de8dbabf9?auto=format&w=1200&q=80&fit=crop\" alt=\"Abstract dark tech background\" class=\"w-full h-full object-cover opacity-20 mix-blend-luminosity\" decoding=\"async\" loading=\"lazy\" data-kid=\"36\">\n            <div class=\"absolute inset-0 bg-[var(--bg-deep)]/40\" data-kid=\"37\"></div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 mesh-gradient pointer-events-none\" data-kid=\"38\">\n            <div class=\"mesh-orb w-[600px] h-[600px] bg-[#FF500B]/15 -top-32 -right-32 animate-pulse\" data-kid=\"39\"></div>\n            <div class=\"mesh-orb w-[500px] h-[500px] bg-purple-600/10 bottom-0 -left-20\" style=\"animation-delay: 1s\" data-kid=\"40\"></div>\n            <div class=\"mesh-orb w-[400px] h-[400px] bg-blue-500/05 top-1/2 left-1/4\" style=\"animation-delay: 2s\" data-kid=\"41\"></div>\n        </div>\n\n        \n        <div class=\"relative z-10 w-full max-w-[480px] animate-float px-6\" data-kid=\"42\">\n            <div class=\"glass-panel rounded-[40px] p-12 space-y-10 group\" data-kid=\"43\">\n                \n                <div class=\"flex items-center justify-between\" data-kid=\"44\">\n                    <div class=\"w-20 h-20 rounded-3xl bg-gradient-to-br from-white/10 to-transparent flex items-center justify-center border border-white/10 shadow-xl group-hover:border-[#FF500B]/30 transition-colors duration-500\" data-kid=\"45\">\n                        <i class=\"ti ti-shield-lock text-5xl text-[#FF500B] drop-shadow-[0_0_15px_rgba(255,80,11,0.5)]\" data-kid=\"46\"></i>\n                    </div>\n                    <div class=\"flex flex-col items-end\" data-kid=\"47\">\n                        <div class=\"px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-full text-[10px] font-bold tracking-wider flex items-center gap-1.5 uppercase\" data-kid=\"48\">\n                            <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"49\"></span>\n                            Encrypted\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"space-y-4\" data-kid=\"50\">\n                    <h2 class=\"text-6xl font-serif text-white leading-[0.9] italic tracking-tight\" data-kid=\"51\">Protect your runway</h2>\n                    <p class=\"text-white/50 text-xl leading-relaxed font-light\" data-kid=\"52\">\n                        Automated cost protection that monitors every API request, ensuring your infrastructure stays lean and secure.\n                    </p>\n                </div>\n\n                \n                <div class=\"space-y-8 pt-4\" data-kid=\"53\">\n                    <div class=\"grid grid-cols-2 gap-8\" data-kid=\"54\">\n                        <div class=\"space-y-1.5\" data-kid=\"55\">\n                            <p class=\"text-[10px] font-bold text-white/30 uppercase tracking-[0.2em]\" data-kid=\"56\">Enforcement</p>\n                            <p class=\"text-lg font-bold text-white tracking-tight\" data-kid=\"57\">Real-time</p>\n                        </div>\n                        <div class=\"space-y-1.5\" data-kid=\"58\">\n                            <p class=\"text-[10px] font-bold text-white/30 uppercase tracking-[0.2em]\" data-kid=\"59\">Safety Ratio</p>\n                            <p class=\"text-lg font-bold text-white tracking-tight\" data-kid=\"60\">99.9%</p>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"space-y-3\" data-kid=\"61\">\n                        <div class=\"flex justify-between items-end\" data-kid=\"62\">\n                            <span class=\"text-[10px] font-bold text-white/40 uppercase tracking-widest\" data-kid=\"63\">Vault Security Status</span>\n                            <span class=\"text-[#FF500B] text-[10px] font-bold\" data-kid=\"64\">OPTIMAL</span>\n                        </div>\n                        <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"65\">\n                            <div class=\"h-full bg-gradient-to-r from-[#FF500B] to-orange-400 w-[85%] rounded-full shadow-[0_0_15px_rgba(255,80,11,0.4)]\" data-kid=\"66\"></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"absolute -bottom-8 -right-4 glass-panel py-4 px-6 rounded-2xl flex items-center gap-4 z-20 border-white/10 group-hover:translate-y-[-5px] transition-transform duration-700\" data-kid=\"67\">\n                <div class=\"w-12 h-12 rounded-full bg-[#FF500B]/20 flex items-center justify-center border border-[#FF500B]/30\" data-kid=\"68\">\n                    <i class=\"ti ti-lock-check text-[#FF500B] text-2xl\" data-kid=\"69\"></i>\n                </div>\n                <div data-kid=\"70\">\n                    <p class=\"text-white text-sm font-bold\" data-kid=\"71\">AES-256 Active</p>\n                    <p class=\"text-white/40 text-[10px] font-mono uppercase tracking-tighter\" data-kid=\"72\">Bank-grade security</p>\n                </div>\n            </div>\n\n            \n            <div class=\"absolute -top-16 -left-16 w-48 h-48 bg-white/5 rounded-full blur-3xl -z-10 pointer-events-none\" data-kid=\"73\"></div>\n        </div>\n\n        \n        <div class=\"absolute bottom-12 left-12 right-12 flex justify-between items-end opacity-20 pointer-events-none font-mono\" data-kid=\"74\">\n            <div class=\"space-y-2\" data-kid=\"75\">\n                <p class=\"text-xs\" data-kid=\"76\">FRG_SEC_SYS_v2.0</p>\n                <div class=\"flex gap-4\" data-kid=\"77\">\n                    <p class=\"text-[8px] leading-tight\" data-kid=\"78\">AUTH_STATUS: ENCRYPTED<br data-kid=\"79\">NODE: SECURE_CLUSTER_A</p>\n                </div>\n            </div>\n            <div class=\"text-right\" data-kid=\"80\">\n                <p class=\"text-4xl font-serif italic leading-none\" data-kid=\"81\">Frugal</p>\n            </div>\n        </div>\n    </section>\n</main>\n",
