      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --primary: #FF500B;\n        --bg-deep: oklch(0.06 0.025 270);\n        --text-crisp: oklch(0.97 0 0);\n    }\n\n    body {\n        margin: 0;\n        padding: 0;\n        background-color: var(--bg-deep);\n        color: var(--text-crisp);\n        font-family: 'Inter', sans-serif;\n        overflow-x: hidden;\n    }\n\n    .mesh-gradient {\n        background: radial-gradient(at 0% 0%, rgba(255, 80, 11, 0.08) 0%, transparent 50%),\n                    radial-gradient(at 100% 100%, rgba(147, 51, 234, 0.05) 0%, transparent 50%);\n    }\n\n    .glass-panel {\n        background: rgba(255, 255, 255, 0.02);\n        backdrop-filter: blur(20px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    .glass-panel:hover {\n        background: rgba(255, 255, 255, 0.04);\n        border-color: rgba(255, 255, 255, 0.15);\n        transform: translateY(-2px);\n    }\n\n    .glass-modal {\n        background: rgba(15, 15, 15, 0.7);\n        backdrop-filter: blur(40px);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n    }\n\n    .sidebar-item-active {\n        background: rgba(255, 255, 255, 0.05);\n        color: white;\n        border: 1px solid rgba(255, 255, 255, 0.05);\n    }\n\n    .primary-shadow {\n        box-shadow: 0 10px 30px -5px rgba(255, 80, 11, 0.3);\n    }\n\n    /* Modal Toggle Hack */\n    #modal-toggle:checked ~ #modal-overlay {\n        display: flex;\n        opacity: 1;\n    }\n</style>\n\n<div class=\"relative min-h-[900px] w-full flex mesh-gradient\" data-kid=\"1\">\n    \n    <input type=\"checkbox\" id=\"modal-toggle\" class=\"hidden\" data-kid=\"2\">\n\n    \n    <aside class=\"w-[280px] shrink-0 border-r border-white/5 flex flex-col h-full sticky top-0 p-8\" data-kid=\"3\">\n        <div class=\"flex items-center gap-3 mb-14\" data-kid=\"4\">\n            <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#FF500B]/20 to-[#FF500B]/5 flex items-center justify-center border border-[#FF500B]/30\" data-kid=\"5\">\n                <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"6\"></i>\n            </div>\n            <span class=\"text-xl font-bold tracking-[0.05em] text-white uppercase\" data-kid=\"7\">Frugal</span>\n        </div>\n\n        <nav class=\"space-y-1.5 grow\" data-kid=\"8\">\n            <p class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.2em] mb-4 ml-4\" data-kid=\"9\">Main Menu</p>\n            <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3 rounded-xl text-white/40 hover:text-white transition-all group\" data-kid=\"10\">\n                <i class=\"ti ti-layout-dashboard text-xl group-hover:text-[#FF500B]\" data-kid=\"11\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"12\">Dashboard</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3 rounded-xl sidebar-item-active group\" data-kid=\"13\">\n                <i class=\"ti ti-api text-xl text-[#FF500B]\" data-kid=\"14\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"15\">API Connections</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3 rounded-xl text-white/40 hover:text-white transition-all group\" data-kid=\"16\">\n                <i class=\"ti ti-brand-google-analytics text-xl group-hover:text-[#FF500B]\" data-kid=\"17\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"18\">Usage Logs</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3 rounded-xl text-white/40 hover:text-white transition-all group\" data-kid=\"19\">\n                <i class=\"ti ti-shield-lock text-xl group-hover:text-[#FF500B]\" data-kid=\"20\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"21\">Security</span>\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3 rounded-xl text-white/40 hover:text-white transition-all group\" data-kid=\"22\">\n                <i class=\"ti ti-credit-card text-xl group-hover:text-[#FF500B]\" data-kid=\"23\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"24\">Billing</span>\n            </a>\n        </nav>\n\n        <div class=\"mt-auto pt-8 border-t border-white/5 space-y-6\" data-kid=\"25\">\n            <a href=\"#\" class=\"flex items-center gap-3.5 px-4 py-3 rounded-xl text-white/40 hover:text-white transition-all group\" data-kid=\"26\">\n                <i class=\"ti ti-settings text-xl group-hover:text-white\" data-kid=\"27\"></i>\n                <span class=\"font-semibold text-sm\" data-kid=\"28\">Settings</span>\n            </a>\n            <div class=\"p-5 rounded-2xl bg-white/5 border border-white/5 relative overflow-hidden group hover:bg-white/[0.08] transition-all cursor-pointer\" data-kid=\"29\">\n                <div class=\"flex items-center gap-4\" data-kid=\"30\">\n                    <div class=\"relative\" data-kid=\"31\">\n                        <img src=\"https://i.pravatar.cc/100?u=alex\" class=\"w-12 h-12 rounded-2xl object-cover\" alt=\"User\" data-kid=\"32\">\n                        <div class=\"absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-emerald-500 border-[3px] border-[oklch(0.06_0.025_270)] rounded-full\" data-kid=\"33\"></div>\n                    </div>\n                    <div class=\"flex-1 min-w-0 flex flex-col justify-center\" data-kid=\"34\">\n                        <p class=\"text-base font-bold text-white truncate leading-tight\" data-kid=\"35\">Alex Rivers</p>\n                        <p class=\"text-[10px] text-white/40 font-bold uppercase tracking-widest truncate\" data-kid=\"36\">Pro Workspace</p>\n                    </div>\n                    <i class=\"ti ti-selector text-white/20 group-hover:text-white/60 transition-colors text-xl\" data-kid=\"37\"></i>\n                </div>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 p-12 min-h-[900px] relative\" data-kid=\"38\">\n        \n        <div class=\"absolute top-20 right-20 w-[400px] h-[400px] bg-[#FF500B]/5 rounded-full blur-[120px] pointer-events-none\" data-kid=\"39\"></div>\n        <div class=\"absolute bottom-40 left-1/3 w-[300px] h-[300px] bg-purple-600/5 rounded-full blur-[100px] pointer-events-none\" data-kid=\"40\"></div>\n\n        <header class=\"flex justify-between items-end mb-16 relative z-10\" data-kid=\"41\">\n            <div class=\"space-y-4\" data-kid=\"42\">\n                <div class=\"flex items-center gap-2 text-[10px] font-bold text-white/20 uppercase tracking-[0.4em]\" data-kid=\"43\">\n                    <span data-kid=\"44\">Workspace</span>\n                    <i class=\"ti ti-chevron-right text-[8px]\" data-kid=\"45\"></i>\n                    <span class=\"text-[#FF500B]\" data-kid=\"46\">API Connections</span>\n                </div>\n                <h1 class=\"text-6xl font-['Instrument_Serif'] italic text-white tracking-tight leading-none\" data-kid=\"47\">API Connections</h1>\n                <div class=\"flex items-center gap-4\" data-kid=\"48\">\n                    <p class=\"text-white/40 text-lg max-w-xl\" data-kid=\"49\">Centralized hub for managing your inference endpoints and monitoring provider health.</p>\n                    <div class=\"h-4 w-px bg-white/10\" data-kid=\"50\"></div>\n                    <div class=\"flex items-center gap-2 text-[10px] font-bold text-emerald-400 uppercase tracking-widest\" data-kid=\"51\">\n                        <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" data-kid=\"52\"></span>\n                      