      "html": "\n<div class=\"min-h-[1400px] bg-[oklch(0.06_0.025_270)] text-[oklch(0.97_0_0)] font-sans relative overflow-hidden\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@300;400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-serif { font-family: 'Instrument Serif', serif; }\n    \n    .mesh-gradient {\n      background: radial-gradient(at 10% 10%, oklch(0.06 0.025 270) 0%, transparent 60%),\n                  radial-gradient(at 90% 10%, rgba(255, 80, 11, 0.12) 0%, transparent 60%),\n                  radial-gradient(at 90% 90%, oklch(0.06 0.025 270) 0%, transparent 60%),\n                  radial-gradient(at 10% 90%, rgba(147, 51, 234, 0.08) 0%, transparent 60%);\n    }\n\n    .mesh-orb {\n      position: absolute;\n      filter: blur(100px);\n      border-radius: 9999px;\n      opacity: 0.5;\n      pointer-events: none;\n    }\n\n    .glass-panel {\n      background: rgba(255, 255, 255, 0.02);\n      backdrop-filter: blur(24px);\n      border: 1px solid rgba(255, 255, 255, 0.06);\n    }\n\n    .nav-active {\n      color: #FF500B;\n      position: relative;\n    }\n    .nav-active::before {\n      content: '';\n      position: absolute;\n      left: -2rem;\n      top: 50%;\n      transform: translateY(-50%);\n      width: 4px;\n      height: 1.5rem;\n      background: #FF500B;\n      border-radius: 0 4px 4px 0;\n      box-shadow: 0 0 15px rgba(255, 80, 11, 0.4);\n    }\n\n    .editorial-step::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 2rem;\n      height: 1px;\n      background: #FF500B;\n      opacity: 0.5;\n    }\n\n    @keyframes float {\n      0%, 100% { transform: translateY(0) rotate(-1deg); }\n      50% { transform: translateY(-20px) rotate(1deg); }\n    }\n    .animate-float { animation: float 10s ease-in-out infinite; }\n    .animate-float-delayed { animation: float 12s ease-in-out infinite 2s; }\n  </style>\n\n  \n  <div class=\"fixed inset-0 mesh-gradient pointer-events-none z-0\" data-kid=\"2\">\n    <div class=\"mesh-orb w-[800px] h-[800px] bg-[#FF500B]/10 -top-40 -left-40 animate-float\" data-kid=\"3\"></div>\n    <div class=\"mesh-orb w-[600px] h-[600px] bg-purple-600/5 -bottom-20 -right-20 animate-float-delayed\" data-kid=\"4\"></div>\n  </div>\n\n  <div class=\"relative z-10 max-w-[1440px] mx-auto flex min-h-[1400px]\" data-kid=\"5\">\n    \n    \n    <aside class=\"w-[380px] border-r border-white/5 py-16 px-12 shrink-0 h-full\" data-kid=\"6\">\n      <div class=\"flex items-center gap-3 mb-24\" data-kid=\"7\">\n        <div class=\"w-10 h-10 bg-[#FF500B] rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(255,80,11,0.3)]\" data-kid=\"8\">\n          <i class=\"ti ti-activity text-white text-xl\" data-kid=\"9\"></i>\n        </div>\n        <div data-kid=\"10\">\n          <p class=\"font-bold text-lg leading-none tracking-tight\" data-kid=\"11\">Frugal.</p>\n          <p class=\"text-white/30 text-[10px] uppercase tracking-[0.25em] mt-1\" data-kid=\"12\">Legal Protocol</p>\n        </div>\n      </div>\n\n      <nav class=\"space-y-16\" data-kid=\"13\">\n        <div data-kid=\"14\">\n          <h4 class=\"text-[10px] font-bold uppercase tracking-[0.4em] text-white/20 mb-8 ml-1\" data-kid=\"15\">Document Sections</h4>\n          <ul class=\"space-y-8\" data-kid=\"16\">\n            <li data-kid=\"17\">\n              <a href=\"#usage\" class=\"nav-active flex items-baseline gap-4 text-sm font-medium transition-colors\" data-kid=\"18\">\n                <span class=\"font-serif italic text-xl opacity-40 w-6\" data-kid=\"19\">01</span> Usage Policy\n              </a>\n            </li>\n            <li data-kid=\"20\">\n              <a href=\"#liability\" class=\"flex items-baseline gap-4 text-sm font-medium text-white/40 hover:text-white/60 transition-colors\" data-kid=\"21\">\n                <span class=\"font-serif italic text-xl opacity-40 w-6\" data-kid=\"22\">02</span> Liability Limits\n              </a>\n            </li>\n            <li data-kid=\"23\">\n              <a href=\"#payment\" class=\"flex items-baseline gap-4 text-sm font-medium text-white/40 hover:text-white/60 transition-colors\" data-kid=\"24\">\n                <span class=\"font-serif italic text-xl opacity-40 w-6\" data-kid=\"25\">03</span> Payment Terms\n              </a>\n            </li>\n            <li data-kid=\"26\">\n              <a href=\"#data\" class=\"flex items-baseline gap-4 text-sm font-medium text-white/40 hover:text-white/60 transition-colors\" data-kid=\"27\">\n                <span class=\"font-serif italic text-xl opacity-40 w-6\" data-kid=\"28\">04</span> Data Protection\n              </a>\n            </li>\n          </ul>\n        </div>\n\n        <div class=\"space-y-4 pt-12 border-t border-white/5\" data-kid=\"29\">\n          <button class=\"w-full py-4 px-6 rounded-2xl bg-white/5 border border-white/10 text-xs font-bold hover:bg-[#FF500B]/10 hover:border-[#FF500B]/30 hover:text-[#FF500B] transition-all flex items-center justify-between group\" data-kid=\"30\">\n            Download PDF <i class=\"ti ti-download opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"31\"></i>\n          </button>\n          <button class=\"w-full py-4 px-6 rounded-2xl bg-white/5 border border-white/10 text-xs font-bold hover:bg-white/10 transition-all flex items-center justify-between group\" data-kid=\"32\">\n            Email Archive <i class=\"ti ti-mail-forward opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"33\"></i>\n          </button>\n        </div>\n\n        <div class=\"mt-auto pt-20\" data-kid=\"34\">\n          <div class=\"glass-panel p-6 rounded-2xl border-white/5\" data-kid=\"35\">\n            <p class=\"text-[10px] font-bold text-white/40 uppercase tracking-widest mb-3\" data-kid=\"36\">Support</p>\n            <p class=\"text-sm text-white/60 leading-relaxed\" data-kid=\"37\">Questions about these terms? Reach out to our legal team.</p>\n            <a href=\"mailto:legal@frugal.ai\" class=\"text-[#FF500B] text-sm font-bold mt-4 block hover:underline\" data-kid=\"38\">legal@frugal.ai</a>\n          </div>\n        </div>\n      </nav>\n    </aside>\n\n    \n    <main class=\"flex-1 py-16 px-20\" data-kid=\"39\">\n      \n      \n      <header class=\"mb-32\" data-kid=\"40\">\n        <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#FF500B]/30 bg-[#FF500B]/5 text-[#FF500B] text-[10px] font-bold uppercase tracking-widest mb-10\" data-kid=\"41\">\n          <span class=\"w-1.5 h-1.5 rounded-full bg-[#FF500B] animate-pulse\" data-kid=\"42\"></span> Document Release v1.4\n        </div>\n        <h1 class=\"text-[11rem] font-serif italic tracking-tighter leading-[0.75] text-white\" data-kid=\"43\">\n          Terms <span class=\"text-[#FF500B]\" data-kid=\"44\">of</span> <br data-kid=\"45\"> Service\n        </h1>\n        <div class=\"mt-16 flex items-end justify-between border-b border-white/5 pb-12\" data-kid=\"46\">\n          <p class=\"text-white/40 text-xl font-light max-w-xl leading-relaxed\" data-kid=\"47\">\n            Governing the intersection of capital and computation. <br data-kid=\"48\">\n            <span class=\"text-white/80 font-medium\" data-kid=\"49\">Last revision: June 15, 2026.</span>\n          </p>\n          <div class=\"text-right\" data-kid=\"50\">\n            <p class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.4em]\" data-kid=\"51\">Jurisdiction</p>\n            <p class=\"text-sm font-medium text-white/60\" data-kid=\"52\">Delaware, United States</p>\n          </div>\n        </div>\n      </header>\n\n      \n      <div class=\"space-y-40 max-w-3xl\" data-kid=\"53\">\n        \n        \n        <section id=\"usage\" class=\"relative pt-12\" data-kid=\"54\">\n          <div class=\"absolute -left-12 top-12 font-serif text-8xl text-[#FF500B]/10 select-none italic\" data-kid=\"55\">01</div>\n          <div class=\"editorial-step pt-8\" data-kid=\"56\">\n            <h2 class=\"text-6xl font-serif italic tracking-tight text-white mb-10\" data-kid=\"57\">Acceptable Usage</h2>\n            <div class=\"space-y-8 text-[oklch(0.97_0_0/0.6)] text-lg leading-relaxed font-light\" data-kid=\"58\">\n              <p data-kid=\"59\">Frugal is designed to help organizations monitor, manage, and optimize their AI API expenditures. By creating an account, you agree to the following operational standards:</p>\n              \n              <div class=\"grid grid-cols-1 gap-6 mt-12\" data-kid=\"60\">\n                <div class=\"glass-panel p-8 rounded-3xl group hover:border-[#FF500B]/30 transition-all duration-500\" data-kid=\"61\">\n                  <div class=\"flex gap-6\" data-kid=\"62\">\n                    <div class=\"w-12 h-12 rounded-2xl bg-[#FF500B]/10 border border-[#FF500B]/20 flex items-center justify-center shrink-0\" data-kid=\"63\">\n                      <i class=\"ti ti-shield-lock text-[#FF500B] text-2xl\" data-kid=\"64\"></i>\n                    </div>\n                    <div data-kid=\"65\">\n                      <h4 class=\"text-white font-bold text-xl mb-3\" data-kid=\"66\">Account Security</h4>\n                      <p class=\"text-sm opacity-80 leading-relaxed\" data-kid=\"67\">You are solely responsible for maintaining the confidentiality of your API keys and login credentials. Any activity conducted through your account is deemed your legal responsibility.</p>\n                    </div>\n                  </div>\n                </div>\n\n                <div class=\"glass-panel p-8 rounded-3xl group hover:border-[#FF500B]/30 transition-all duration-500\" data-kid=\"68\">\n                  <div class=\"flex gap-6\" data-kid=\"69\">\n                    <div class=\"w-12 h-12 rounded-2xl bg-[#FF500B]/10 border border-[#FF500B]/20 flex items-center justify-center shrink-0\" data-kid=\"70\">\n                      <i class=\"ti ti-ban text-[#FF500B] text-2xl\" data-kid=\"71\"></i>\n                    </div>\n                    <div data-kid=\"72\">\n                      <h4 class=\"text-white font-bold text-xl mb-3\" data-kid=\"73\">Prohibited Use</h4>\n                      <p class=\"text-sm opacity-80 leading-relaxed\" data-kid=\"74\">You may not use Frugal for any unlawful purpose, including but not limited to, attempting to circumvent provider-imposed API limits or reverse-engineering the Frugal platform.</p>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"mt-12 p-8 border border-[#FF500B]/20 bg-[#FF500B]/5 rounded-3xl flex gap-6 items-start\" data-kid=\"75\">\n                <i class=\"ti ti-alert-triangle text-[#FF500B] text-2xl mt-1\" data-kid=\"76\"></i>\n                <div class=\"text-sm text-white/80\" data-kid=\"77\">\n                  <p class=\"font-bold mb-1\" data-kid=\"78\">Notice on Termination</p>\n                  <p class=\"opacity-70 leading-relaxed\" data-kid=\"79\">Frugal reserves the right to suspend or terminate access immediately if usage patterns suggest abuse or non-compliance with regional data laws, specifically the Digital Personal Data Protection (DPDP) Act 2023.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        \n        <section id=\"liability\" class=\"relative pt-12\" data-kid=\"80\">\n          <div class=\"absolute -left-12 top-12 font-serif text-8xl text-[#FF500B]/10 select-none italic\" data-kid=\"81\">02</div>\n          <div class=\"editorial-step pt-8\" data-kid=\"82\">\n            <h2 class=\"text-6xl font-serif italic tracking-tight text-white mb-10\" data-kid=\"83\">Liability Limits</h2>\n            <div class=\"space-y-8 text-[oklch(0.97_0_0/0.6)] text-lg leading-relaxed font-light\" data-kid=\"84\">\n              <p data-kid=\"85\">To the maximum extent permitted by law, Frugal and Gray Matter Labs shall not be held liable for any indirect, incidental, special, or consequential damages resulting from the use of our services.</p>\n              \n              <div class=\"grid grid-cols-2 gap-6 mt-12\" data-kid=\"86\">\n                <div class=\"p-8 border border-white/5 bg-white/[0.02] rounded-3xl\" data-kid=\"87\">\n                  <h5 class=\"font-bold text-white mb-4 flex items-center gap-2\" data-kid=\"88\">\n                    <i class=\"ti ti-cloud-off text-[#FF500B]/60\" data-kid=\"89\"></i> Service Uptime\n                  </h5>\n                  <p class=\"text-sm opacity-70 leading-relaxed\" data-kid=\"90\">We do not guarantee 100% uptime. While we strive for excellence, we are not liable for costs incurred due to system downtime or API sync delays.</p>\n                </div>\n                <div class=\"p-8 border border-white/5 bg-white/[0.02] rounded-3xl\" data-kid=\"91\">\n                  <h5 class=\"font-bold text-white mb-4 flex items-center gap-2\" data-kid=\"92\">\n                    <i class=\"ti ti-link text-[#FF500B]/60\" data-kid=\"93\"></i> Third-Party APIs\n                  </h5>\n                  <p class=\"text-sm opacity-70 leading-relaxed\" data-kid=\"94\">Frugal acts as a middleware. Any billing disputes with third-party providers must be resolved directly with said providers.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        \n        <section id=\"payment\" class=\"relative pt-12\" data-kid=\"95\">\n          <div class=\"absolute -left-12 top-12 font-serif text-8xl text-[#FF500B]/10 select-none italic\" data-kid=\"96\">03</div>\n          <div class=\"editorial-step pt-8\" data-kid=\"97\">\n            <h2 class=\"text-6xl font-serif italic tracking-tight text-white mb-10\" data-kid=\"98\">Payment Protocol</h2>\n            <div class=\"space-y-8 text-[oklch(0.97_0_0/0.6)] text-lg leading-relaxed font-light\" data-kid=\"99\">\n              <p data-kid=\"100\">Frugal offers various subscription tiers for individual developers and large-scale enterprises. Our billing is handled through verified processors including Stripe and Lemon Squeezy.</p>\n              \n              <ul class=\"space-y-6\" data-kid=\"101\">\n                <li class=\"flex gap-6 items-start pb-6 border-b border-white/5\" data-kid=\"102\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-[#FF500B] mt-3 shrink-0\" data-kid=\"103\"></span>\n                  <div data-kid=\"104\">\n                    <strong class=\"text-white font-bold block mb-1\" data-kid=\"105\">7-Day Refund Window</strong>\n                    <p class=\"text-sm opacity-70\" data-kid=\"106\">We offer a no-questions-asked 7-day refund window for all new SaaS subscriptions to build trust and reduce disputes.</p>\n                  </div>\n                </li>\n                <li class=\"flex gap-6 items-start pb-6 border-b border-white/5\" data-kid=\"107\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-[#FF500B] mt-3 shrink-0\" data-kid=\"108\"></span>\n                  <div data-kid=\"109\">\n                    <strong class=\"text-white font-bold block mb-1\" data-kid=\"110\">Global Tax Compliance</strong>\n                    <p class=\"text-sm opacity-70\" data-kid=\"111\">GST of 18% is applicable to Indian business customers. Export of services to overseas customers is zero-rated under GST regulations.</p>\n                  </div>\n                </li>\n              </ul>\n            </div>\n          </div>\n        </section>\n\n        \n        <section id=\"data\" class=\"relative pt-12\" data-kid=\"112\">\n          <div class=\"absolute -left-12 top-12 font-serif text-8xl text-[#FF500B]/10 select-none italic\" data-kid=\"113\">04</div>\n          <div class=\"editorial-step pt-8\" data-kid=\"114\">\n            <h2 class=\"text-6xl font-serif italic tracking-tight text-white mb-10\" data-kid=\"115\">Data Protection</h2>\n            <div class=\"space-y-8 text-[oklch(0.97_0_0/0.6)] text-lg leading-relaxed font-light\" data-kid=\"116\">\n              <p data-kid=\"117\">Frugal processes sensitive personal data, including email addresses and API keys. We adhere strictly to the Digital Personal Data Protection (DPDP) Act 2023 and GDPR mandates.</p>\n              \n              <div class=\"glass-panel p-10 rounded-3xl bg-gradient-to-br from-white/[0.04] to-transparent\" data-kid=\"118\">\n                <h4 class=\"text-white font-bold mb-6 flex items-center gap-3 text-xl\" data-kid=\"119\">\n                  <i class=\"ti ti-world text-[#FF500B]\" data-kid=\"120\"></i> Global Compliance Commitments\n                </h4>\n                <div class=\"grid grid-cols-2 gap-8\" data-kid=\"121\">\n                  <ul class=\"text-sm space-y-4 text-white/70\" data-kid=\"122\">\n                    <li class=\"flex gap-3\" data-kid=\"123\"><i class=\"ti ti-circle-check text-[#FF500B]/60 text-lg\" data-kid=\"124\"></i> Explicit consent-based collection</li>\n                    <li class=\"flex gap-3\" data-kid=\"125\"><i class=\"ti ti-circle-check text-[#FF500B]/60 text-lg\" data-kid=\"126\"></i> Right to erasure and data purging</li>\n                  </ul>\n                  <ul class=\"text-sm space-y-4 text-white/70\" data-kid=\"127\">\n                    <li class=\"flex gap-3\" data-kid=\"128\"><i class=\"ti ti-circle-check text-[#FF500B]/60 text-lg\" data-kid=\"129\"></i> Essential-only data processing</li>\n                    <li class=\"flex gap-3\" data-kid=\"130\"><i class=\"ti ti-circle-check text-[#FF500B]/60 text-lg\" data-kid=\"131\"></i> Valid DPA with all processors</li>\n                  </ul>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        \n        <footer class=\"pt-20 border-t border-white/5\" data-kid=\"132\">\n          <div class=\"flex items-center justify-between opacity-30 text-xs uppercase tracking-[0.3em]\" data-kid=\"133\">\n            <p data-kid=\"134\">© 2026 Gray Matter Labs</p>\n            <div class=\"flex gap-8\" data-kid=\"135\">\n              <a href=\"#\" class=\"hover:text-white\" data-kid=\"136\">Privacy</a>\n              <a href=\"#\" class=\"hover:text-white\" data-kid=\"137\">Cookies</a>\n              <a href=\"#\" class=\"hover:text-white\" data-kid=\"138\">Security</a>\n            </div>\n          </div>\n          <div class=\"mt-12 text-center\" data-kid=\"139\">\n             <p class=\"font-serif italic text-4xl text-white opacity-10\" data-kid=\"140\">Frugal.</p>\n          </div>\n        </footer>\n\n      </div>\n    </main>\n  </div>\n</div>\n",
