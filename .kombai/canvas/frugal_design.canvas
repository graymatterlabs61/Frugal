          <div class=\"relative\" data-kid=\"211\">\n                            <select class=\"w-full px-6 py-5 rounded-2xl input-field text-white appearance-none cursor-pointer\" data-kid=\"212\">\n                                <option value disabled selected data-kid=\"213\">Identify project or workspace...</option>\n                                <option data-kid=\"214\">AWS Cloud - Prod Alpha</option>\n                                <option data-kid=\"215\">GCP - Data Warehouse</option>\n                                <option data-kid=\"216\">Azure - Legacy Systems</option>\n                                <option data-kid=\"217\">Stripe API - Global</option>\n                            </select>\n                            <i class=\"ti ti-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-white/20 pointer-events-none\" data-kid=\"218\"></i>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"space-y-4\" data-kid=\"219\">\n                        <label class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-white/30 ml-1\" data-kid=\"220\">Spending Limit (USD)</label>\n                        <div class=\"relative\" data-kid=\"221\">\n                            <span class=\"absolute left-6 top-1/2 -translate-y-1/2 text-white/20 font-bold\" data-kid=\"222\">$</span>\n                            <input type=\"number\" placeholder=\"5000.00\" class=\"w-full pl-12 pr-6 py-5 rounded-2xl input-field text-white placeholder:text-white/10 font-bold\" data-kid=\"223\">\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"space-y-4\" data-kid=\"224\">\n                        <label class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-white/30 ml-1\" data-kid=\"225\">Shield Threshold (%)</label>\n                        <div class=\"relative\" data-kid=\"226\">\n                            <input type=\"number\" placeholder=\"85\" class=\"w-full px-6 py-5 rounded-2xl input-field text-white placeholder:text-white/10 font-bold\" data-kid=\"227\">\n                            <span class=\"absolute right-6 top-1/2 -translate-y-1/2 text-white/20 font-bold\" data-kid=\"228\">%</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"col-span-2 space-y-4\" data-kid=\"229\">\n                        <label class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-white/30 ml-1\" data-kid=\"230\">Enforcement Action</label>\n                        <div class=\"grid grid-cols-3 gap-4\" data-kid=\"231\">\n                            <label class=\"relative group cursor-pointer\" data-kid=\"232\">\n                                <input type=\"radio\" name=\"modal_action\" class=\"peer hidden\" checked data-kid=\"233\">\n                                <div class=\"h-full p-5 rounded-2xl border border-white/5 bg-white/2 peer-checked:border-[var(--primary)]/50 peer-checked:bg-[var(--primary)]/10 hover:bg-white/5 transition-all\" data-kid=\"234\">\n                                    <div class=\"w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 mb-4\" data-kid=\"235\">\n                                        <i class=\"ti ti-bell\" data-kid=\"236\"></i>\n                                    </div>\n                                    <p class=\"font-bold text-white text-sm mb-1\" data-kid=\"237\">Notify</p>\n                                    <p class=\"text-[10px] text-white/30 leading-relaxed\" data-kid=\"238\">Alert team via Slack and Email only.</p>\n                                </div>\n                            </label>\n                            <label class=\"relative group cursor-pointer\" data-kid=\"239\">\n                                <input type=\"radio\" name=\"modal_action\" class=\"peer hidden\" data-kid=\"240\">\n                                <div class=\"h-full p-5 rounded-2xl border border-white/5 bg-white/2 peer-checked:border-amber-500/50 peer-checked:bg-amber-500/10 hover:bg-white/5 transition-all\" data-kid=\"241\">\n                                    <div class=\"w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-400 mb-4\" data-kid=\"242\">\n                                        <i class=\"ti ti-adjustments-alt\" data-kid=\"243\"></i>\n                                    </div>\n                                    <p class=\"font-bold text-white text-sm mb-1\" data-kid=\"244\">Throttle</p>\n                                    <p class=\"text-[10px] text-white/30 leading-relaxed\" data-kid=\"245\">Scale down non-critical services.</p>\n                                </div>\n                            </label>\n                            <label class=\"relative group cursor-pointer\" data-kid=\"246\">\n                                <input type=\"radio\" name=\"modal_action\" class=\"peer hidden\" data-kid=\"247\">\n                                <div class=\"h-full p-5 rounded-2xl border border-white/5 bg-white/2 peer-checked:border-red-500/50 peer-checked:bg-red-500/10 hover:bg-white/5 transition-all\" data-kid=\"248\">\n                                    <div class=\"w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center text-red-400 mb-4\" data-kid=\"249\">\n                                        <i class=\"ti ti-power\" data-kid=\"250\"></i>\n                                    </div>\n                                    <p class=\"font-bold text-white text-sm mb-1\" data-kid=\"251\">Shutdown</p>\n                                    <p class=\"text-[10px] text-white/30 leading-relaxed\" data-kid=\"252\">Kill all resources immediately.</p>\n                                </div>\n                            </label>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"flex gap-4 pt-4\" data-kid=\"253\">\n                    <label for=\"modal-toggle\" class=\"flex-1 py-5 rounded-2xl border border-white/10 text-white font-bold text-center hover:bg-white/5 transition-all cursor-pointer\" data-kid=\"254\">Discard</label>\n                    <button type=\"submit\" class=\"flex-[2] py-5 rounded-2xl bg-[var(--primary)] text-white font-bold shadow-[0_15px_30px_rgba(255,80,11,0.4)] hover:scale-[1.02] active:scale-100 transition-all\" data-kid=\"255\">Activate Shield Rule</button>\n                </div>\n            </form>\n        </div>\n    </div>\n</div>\n",
