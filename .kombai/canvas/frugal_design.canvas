      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --primary: #FF500B;\n        --bg-deep: oklch(0.06 0.025 270);\n        --text-crisp: oklch(0.97 0 0);\n    }\n\n    body {\n        margin: 0;\n        padding: 0;\n        background-color: var(--bg-deep);\n        color: var(--text-crisp);\n        font-family: 'Inter', sans-serif;\n        overflow-x: hidden;\n    }\n\n    .mesh-gradient {\n        background: radial-gradient(at 10% 10%, var(--bg-deep) 0%, transparent 60%),\n                    radial-gradient(at 90% 10%, rgba(255, 80, 11, 0.12) 0%, transparent 60%),\n                    radial-gradient(at 90% 90%, var(--bg-deep) 0%, transparent 60%),\n                    radial-gradient(at 10% 90%, rgba(147, 51, 234, 0.08) 0%, transparent 60%);\n    }\n\n    .mesh-orb {\n        position: absolute;\n        filter: blur(120px);\n        border-radius: 9999px;\n        z-index: 0;\n        opacity: 0.4;\n    }\n\n    .glass-panel {\n        background: rgba(255, 255, 255, 0.02);\n        backdrop-filter: blur(32px);\n        border: 1px solid rgba(255, 255, 255, 0.06);\n        box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.7);\n    }\n\n    .sidebar-link {\n        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n        position: relative;\n    }\n    \n    .sidebar-link::before {\n        content: '';\n        position: absolute;\n        left: -16px;\n        top: 50%;\n        transform: translateY(-50%) scaleX(0);\n        width: 2px;\n        height: 16px;\n        background: var(--primary);\n        transition: transform 0.3s ease;\n        transform-origin: left;\n    }\n\n    .sidebar-link.active::before {\n        transform: translateY(-50%) scaleX(1);\n    }\n\n    .sidebar-link.active {\n        color: var(--primary);\n        background: rgba(255, 80, 11, 0.05);\n    }\n\n    .legal-content h2 {\n        font-family: 'Instrument Serif', serif;\n        font-style: italic;\n        font-size: 2.25rem;\n        line-height: 1.2;\n        color: white;\n        margin-top: 3rem;\n        margin-bottom: 1.5rem;\n    }\n\n    .legal-content h3 {\n        font-weight: 600;\n        font-size: 1.125rem;\n        color: white;\n        margin-top: 2rem;\n        margin-bottom: 0.75rem;\n    }\n\n    .legal-content p {\n        color: rgba(255, 255, 255, 0.75);\n        line-height: 1.8;\n        margin-bottom: 1.25rem;\n    }\n\n    .legal-content ul {\n        list-style-type: none;\n        padding-left: 0;\n        margin-bottom: 1.5rem;\n    }\n\n    .legal-content li {\n        position: relative;\n        padding-left: 1.5rem;\n        color: rgba(255, 255, 255, 0.75);\n        margin-bottom: 0.75rem;\n    }\n\n    .legal-content li::before {\n        content: '•';\n        position: absolute;\n        left: 0;\n        color: var(--primary);\n        font-weight: bold;\n    }\n\n    @keyframes float {\n        0%, 100% { transform: translateY(0); }\n        50% { transform: translateY(-20px); }\n    }\n\n    .animate-float {\n        animation: float 10s ease-in-out infinite;\n    }\n\n    table {\n        width: 100%;\n        border-collapse: separate;\n        border-spacing: 0;\n        margin: 2.5rem 0;\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        border-radius: 1.25rem;\n        overflow: hidden;\n    }\n\n    th {\n        background: rgba(255, 255, 255, 0.04);\n        text-align: left;\n        padding: 1.25rem 1rem;\n        font-size: 0.7rem;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.15em;\n        color: rgba(255, 255, 255, 0.35);\n        border-bottom: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    td {\n        padding: 1rem;\n        border-bottom: 1px solid rgba(255, 255, 255, 0.03);\n        color: rgba(255, 255, 255, 0.6);\n        font-size: 0.875rem;\n    }\n\n    tr:last-child td {\n        border-bottom: none;\n    }\n</style>\n\n<div class=\"relative w-full min-h-[1400px] overflow-hidden mesh-gradient pb-32\" data-kid=\"1\">\n    \n    <div class=\"mesh-orb w-[800px] h-[800px] bg-[#FF500B]/20 -top-64 -right-32 animate-float\" data-kid=\"2\"></div>\n    <div class=\"mesh-orb w-[600px] h-[600px] bg-purple-600/10 bottom-0 -left-64\" style=\"animation-delay: -5s\" data-kid=\"3\"></div>\n\n    \n    <header class=\"relative z-10 w-full px-12 py-10 flex justify-between items-center max-w-[1440px] mx-auto\" data-kid=\"4\">\n        <div class=\"flex items-center gap-4\" data-kid=\"5\">\n            <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#FF500B]/20 to-[#FF500B]/5 flex items-center justify-center border border-[#FF500B]/30 shadow-[0_0_15px_rgba(255,80,11,0.1)]\" data-kid=\"6\">\n                <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"7\"></i>\n            </div>\n            <span class=\"text-xl font-bold tracking-[0.05em] text-[var(--text-crisp)] uppercase\" data-kid=\"8\">Frugal</span>\n        </div>\n        <nav class=\"flex items-center gap-10\" data-kid=\"9\">\n            <a href=\"#\" class=\"text-sm font-medium text-white/60 hover:text-white transition-colors\" data-kid=\"10\">Platform</a>\n            <a href=\"#\" class=\"text-sm font-medium text-white/60 hover:text-white transition-colors\" data-kid=\"11\">Pricing</a>\n            <a href=\"#\" class=\"text-sm font-medium text-white/60 hover:text-white transition-colors\" data-kid=\"12\">Resources</a>\n            <a href=\"#\" class=\"px-5 py-2.5 bg-white/5 border border-white/10 rounded-xl text-sm font-bold hover:bg-white/10 transition-all\" data-kid=\"13\">Sign In</a>\n        </nav>\n    </header>\n\n    \n    <main class=\"relative z-10 max-w-[1440px] mx-auto px-12 mt-12 flex gap-20 items-start\" data-kid=\"14\">\n        \n        \n        <aside class=\"w-72 shrink-0 space-y-12\" data-kid=\"15\">\n            <div class=\"space-y-6\" data-kid=\"16\">\n                <div class=\"flex items-center gap-2 text-white/30\" data-kid=\"17\">\n                    <i class=\"ti ti-gavel text-sm\" data-kid=\"18\"></i>\n                    <h3 class=\"text-[10px] font-bold uppercase tracking-[0.3em]\" data-kid=\"19\">Legal Center</h3>\n                </div>\n                <nav class=\"flex flex-col gap-1\" data-kid=\"20\">\n                    <a href=\"#cookie-policy\" class=\"sidebar-link active group flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5\" data-kid=\"21\">\n                        <i class=\"ti ti-cookie text-lg opacity-100 transition-opacity\" data-kid=\"22\"></i>\n                        <span class=\"font-semibold tracking-tight\" data-kid=\"23\">Cookie Policy</span>\n                        <div class=\"ml-auto w-1 h-1 rounded-full bg-primary shadow-[0_0_8px_var(--primary)]\" data-kid=\"24\"></div>\n                    </a>\n                    <a href=\"#refund-policy\" class=\"sidebar-link group flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/50\" data-kid=\"25\">\n                        <i class=\"ti ti-receipt-refund text-lg opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"26\"></i>\n                        <span class=\"font-semibold tracking-tight\" data-kid=\"27\">Refund Policy</span>\n                    </a>\n                    <a href=\"#\" class=\"sidebar-link group flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/50\" data-kid=\"28\">\n                        <i class=\"ti ti-shield-lock text-lg opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"29\"></i>\n                        <span class=\"font-semibold tracking-tight\" data-kid=\"30\">Privacy Policy</span>\n                    </a>\n                    <a href=\"#\" class=\"sidebar-link group flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-white/50\" data-kid=\"31\">\n                        <i class=\"ti ti-file-text text-lg opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"32\"></i>\n                        <span class=\"font-semibold tracking-tight\" data-kid=\"33\">Terms of Service</span>\n                    </a>\n                </nav>\n            </div>\n\n            <div class=\"space-y-6\" data-kid=\"34\">\n                <div class=\"flex items-center gap-2 text-white/30\" data-kid=\"35\">\n                    <i class=\"ti ti-list text-sm\" data-kid=\"36\"></i>\n                    <h3 class=\"text-[10px] font-bold uppercase tracking-[0.3em]\" data-kid=\"37\">Quick Links</h3>\n                </div>\n                <nav class=\"flex flex-col gap-4 pl-4 text-xs font-medium text-white/40\" data-kid=\"38\">\n                    <a href=\"#intro\" class=\"hover:text-[#FF500B] transition-colors\" data-kid=\"39\">1. Scope of Use</a>\n                    <a href=\"#what-cookies\" class=\"hover:text-[#FF500B] transition-colors\" data-kid=\"40\">2. Technologies Used</a>\n                    <a href=\"#how-use\" class=\"hover:text-[#FF500B] transition-colors\" data-kid=\"41\">3. Third-party Pixels</a>\n                    <a href=\"#manage\" class=\"hover:text-[#FF500B] transition-colors\" data-kid=\"42\">4. Your Control</a>\n                    <a href=\"#refund-scope\" class=\"hover:text-[#FF500B] transition-colors\" data-kid=\"43\">5. Refund Eligibility</a>\n                    <a href=\"#refund-process\" class=\"hover:text-[#FF500B] transition-colors\" data-kid=\"44\">6. Processing Times</a>\n                </nav>\n            </div>\n\n            \n            <div class=\"glass-panel p-6 rounded-2xl border-white/5 space-y-4\" data-kid=\"45\">\n                <div class=\"w-10 h-10 rounded-full bg-[#FF500B]/10 flex items-center justify-center text-[#FF500B]\" data-kid=\"46\">\n                    <i class=\"ti ti-help-circle text-xl\" data-kid=\"47\"></i>\n                </div>\n                <div class=\"space-y-1\" data-kid=\"48\">\n                    <h4 class=\"font-bold text-sm\" data-kid=\"49\">Need clarification?</h4>\n                    <p class=\"text-xs text-white/40 leading-relaxed\" data-kid=\"50\">Our legal team is available to help explain any terms.</p>\n                </div>\n                <a href=\"#\" class=\"block text-center py-2 bg-white/5 hover:bg-white/10 rounded-lg text-xs font-bold transition-all\" data-kid=\"51\">Contact Legal</a>\n            </div>\n\n            <div class=\"p-6 border-l border-white/5 space-y-4\" data-kid=\"52\">\n                <h4 class=\"text-[10px] font-bold uppercase tracking-widest text-white/20\" data-kid=\"53\">Compliance</h4>\n                <div class=\"space-y-4\" data-kid=\"54\">\n                    <div class=\"flex items-center gap-3 text-xs text-white/40 hover:text-white/60 transition-colors cursor-default group\" data-kid=\"55\">\n                        <i class=\"ti ti-certificate text-primary scale-110 group-hover:rotate-12 transition-transform\" data-kid=\"56\"></i>\n                        <span data-kid=\"57\">GDPR Compliant</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 text-xs text-white/40 hover:text-white/60 transition-colors cursor-default group\" data-kid=\"58\">\n                        <i class=\"ti ti-lock text-primary scale-110 group-hover:rotate-12 transition-transform\" data-kid=\"59\"></i>\n                        <span data-kid=\"60\">SOC2 Type II</span>\n                    </div>\n                    <div class=\"flex items-center gap-3 text-xs text-white/40 hover:text-white/60 transition-colors cursor-default group\" data-kid=\"61\">\n                        <i class=\"ti ti-world text-primary scale-110 group-hover:rotate-12 transition-transform\" data-kid=\"62\"></i>\n                        <span data-kid=\"63\">Privacy Shield</span>\n                    </div>\n                </div>\n            </div>\n        </aside>\n\n        \n        <div class=\"flex-1 max-w-[880px]\" data-kid=\"64\">\n            <div class=\"glass-panel rounded-[2rem] p-16 relative overflow-hidden\" data-kid=\"65\">\n                \n                <div class=\"absolute -top-32 -left-32 w-64 h-64 bg-[#FF500B]/10 blur-[80px]\" data-kid=\"66\"></div>\n                \n                <div class=\"relative z-10 legal-content\" data-kid=\"67\">\n                    <header class=\"space-y-6 mb-16 pb-12 border-b border-white/10\" data-kid=\"68\">\n                        <div class=\"inline-flex items-center gap-3 px-4 py-1.5 bg-[#FF500B]/15 border border-[#FF500B]/30 rounded-full\" data-kid=\"69\">\n                            <span class=\"w-1.5 h-1.5 rounded-full bg-[#FF500B] shadow-[0_0_8px_rgba(255,80,11,0.8)] animate-pulse\" data-kid=\"70\"></span>\n                            <span class=\"text-[10px] font-bold text-[#FF500B] tracking-[0.2em] uppercase\" data-kid=\"71\">Policy Rev. 2024.4</span>\n                        </div>\n                        <h1 class=\"text-9xl font-['Instrument_Serif'] italic leading-[0.9] tracking-tighter\" data-kid=\"72\">Legal <br data-kid=\"73\"><span class=\"text-white/10 font-normal\" data-kid=\"74\">and</span> Policies</h1>\n                        <p class=\"text-xl text-white/50 font-medium max-w-[520px] leading-relaxed mt-4\" data-kid=\"75\">Transparent and comprehensive documentation regarding data processing, cookie usage, and financial transactions at Frugal.</p>\n                    </header>\n\n                    \n                    <div id=\"cookie-policy\" class=\"scroll-mt-32\" data-kid=\"76\">\n                        <div class=\"flex items-center gap-4 mb-12\" data-kid=\"77\">\n                            <div class=\"h-px flex-1 bg-white/5\" data-kid=\"78\"></div>\n                            <span class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.8em]\" data-kid=\"79\">Cookie Policy</span>\n                            <div class=\"h-px flex-1 bg-white/5\" data-kid=\"80\"></div>\n                        </div>\n\n                        <h2 id=\"intro\" data-kid=\"81\">1. Scope of Application</h2>\n                        <p data-kid=\"82\">This Cookie Policy applies to all Frugal platforms, including our main application dashboard, API documentation, and marketing assets. By continuing to browse our site, you agree to our use of cookies as described herein. We are committed to transparency in our data processing practices.</p>\n\n                        <h2 id=\"what-cookies\" data-kid=\"83\">2. Technologies Used</h2>\n                        <p data-kid=\"84\">Frugal uses cookies, web beacons, and other tracking technologies to provide a seamless cloud cost monitoring experience. These can be categorized as follows:</p>\n                        \n                        <table data-kid=\"85\">\n                            <thead data-kid=\"86\">\n                                <tr data-kid=\"87\">\n                                    <th data-kid=\"88\">Category</th>\n                                    <th data-kid=\"89\">Purpose</th>\n                                    <th data-kid=\"90\">Retention</th>\n                                </tr>\n                            </thead>\n                            <tbody data-kid=\"91\">\n                                <tr data-kid=\"92\">\n                                    <td class=\"font-bold text-white\" data-kid=\"93\">Essential</td>\n                                    <td data-kid=\"94\">Authentication, security, and load balancing.</td>\n                                    <td data-kid=\"95\">Session</td>\n                                </tr>\n                                <tr data-kid=\"96\">\n                                    <td class=\"font-bold text-white\" data-kid=\"97\">Functional</td>\n                                    <td data-kid=\"98\">Preferences, currency settings, and theme.</td>\n                                    <td data-kid=\"99\">1 Year</td>\n                                </tr>\n                                <tr data-kid=\"100\">\n                                    <td class=\"font-bold text-white\" data-kid=\"101\">Analytics</td>\n                                    <td data-kid=\"102\">Performance metrics and spend visualization.</td>\n                                    <td data-kid=\"103\">2 Years</td>\n                                </tr>\n                            </tbody>\n                        </table>\n\n                        <h2 id=\"how-use\" data-kid=\"104\">3. How we use them</h2>\n                        <p data-kid=\"105\">We leverage these technologies to ensure that your Frugal experience is optimized. Specifically:</p>\n                        <ul data-kid=\"106\">\n                            <li data-kid=\"107\"><strong data-kid=\"108\">Security:</strong> We use cookies to verify your identity and prevent fraudulent access to your spend dashboard.</li>\n                            <li data-kid=\"109\"><strong data-kid=\"110\">Performance:</strong> Analyzing which cloud regions are being monitored most frequently helps us optimize our ingestion engine.</li>\n                            <li data-kid=\"111\"><strong data-kid=\"112\">Preferences:</strong> Remembering your graph layouts and alert thresholds so you don't have to reconfigure them every visit.</li>\n                        </ul>\n\n                        <div class=\"bg-[#FF500B]/5 border border-[#FF500B]/20 rounded-2xl p-8 my-10 space-y-4\" data-kid=\"113\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"114\">\n                                <div class=\"w-8 h-8 rounded-lg bg-[#FF500B] flex items-center justify-center shadow-lg\" data-kid=\"115\">\n                                    <i class=\"ti ti-bulb text-white text-lg\" data-kid=\"116\"></i>\n                                </div>\n                                <h4 class=\"text-white font-bold\" data-kid=\"117\">Privacy Note</h4>\n                            </div>\n                            <p class=\"text-sm text-white/60 leading-relaxed mb-0\" data-kid=\"118\">Frugal never sells your cookie data to third-party advertisers. All analytical data is anonymized and used strictly for platform improvement and system health monitoring.</p>\n                        </div>\n                    </div>\n\n                    \n                    <div id=\"refund-policy\" class=\"mt-32 pt-24 border-t border-white/10 scroll-mt-32\" data-kid=\"119\">\n                        <div class=\"flex items-center gap-4 mb-12\" data-kid=\"120\">\n                            <div class=\"h-px flex-1 bg-white/5\" data-kid=\"121\"></div>\n                            <span class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.8em]\" data-kid=\"122\">Refund Policy</span>\n                            <div class=\"h-px flex-1 bg-white/5\" data-kid=\"123\"></div>\n                        </div>\n\n                        <h2 id=\"refund-scope\" data-kid=\"124\">4. Refund Eligibility</h2>\n                        <p data-kid=\"125\">At Frugal, we strive to provide the most accurate cloud cost forecasting tools. If our platform fails to meet the Service Level Agreement (SLA) or if you are unsatisfied with the initial experience, the following rules apply:</p>\n                        <ul data-kid=\"126\">\n                            <li data-kid=\"127\"><strong data-kid=\"128\">14-Day Satisfaction:</strong> New users are eligible for a full refund within the first 14 days of their initial subscription.</li>\n                            <li data-kid=\"129\"><strong data-kid=\"130\">System Failures:</strong> If our cost guards fail to alert you based on your defined thresholds, a pro-rated credit will be issued.</li>\n                            <li data-kid=\"131\"><strong data-kid=\"132\">Annual Plans:</strong> Refunds for annual plans are calculated based on the remaining full months of the term.</li>\n                        </ul>\n\n                        <h2 id=\"refund-process\" data-kid=\"133\">5. Refund Processing</h2>\n                        <p data-kid=\"134\">All refund requests must be submitted through the Billing Dashboard or via email to <a href=\"mailto:billing@frugal.io\" class=\"text-[#FF500B] hover:underline\" data-kid=\"135\">billing@frugal.io</a>. Once approved, the funds will be returned to the original payment method.</p>\n                        \n                        <div class=\"grid grid-cols-2 gap-6 mt-8\" data-kid=\"136\">\n                            <div class=\"p-6 rounded-2xl bg-white/5 border border-white/10\" data-kid=\"137\">\n                                <h4 class=\"text-white font-bold mb-2\" data-kid=\"138\">Credit Card</h4>\n                                <p class=\"text-xs text-white/40 mb-0\" data-kid=\"139\">Processing takes 5-10 business days depending on your bank provider.</p>\n                            </div>\n                            <div class=\"p-6 rounded-2xl bg-white/5 border border-white/10\" data-kid=\"140\">\n                                <h4 class=\"text-white font-bold mb-2\" data-kid=\"141\">Bank Transfer</h4>\n                                <p class=\"text-xs text-white/40 mb-0\" data-kid=\"142\">May take up to 15 business days for international settlements.</p>\n                            </div>\n                        </div>\n\n                        <h2 id=\"manage\" data-kid=\"143\">6. Subscription Changes</h2>\n                        <p data-kid=\"144\">Downgrading your plan mid-cycle will result in a prorated credit applied to your next billing period. We do not offer cash refunds for mid-cycle plan downgrades unless specifically required by regional consumer protection laws.</p>\n                    </div>\n\n                    <footer class=\"mt-32 pt-12 border-t border-white/5 flex justify-between items-center text-white/30 text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"145\">\n                        <div data-kid=\"146\">© 2024 Frugal Technologies Inc.</div>\n                        <div class=\"flex gap-8\" data-kid=\"147\">\n                            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"148\">Privacy</a>\n                            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"149\">Security</a>\n                            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"150\">Status</a>\n                        </div>\n                    </footer>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    \n    <div class=\"absolute bottom-12 right-12 z-50\" data-kid=\"151\">\n        <button class=\"w-16 h-16 rounded-full bg-[#FF500B] text-white shadow-[0_20px_50px_rgba(255,80,11,0.5)] flex items-center justify-center hover:scale-110 transition-all active:scale-95 group cursor-pointer border-4 border-[var(--bg-deep)]\" data-kid=\"152\">\n            <i class=\"ti ti-message-circle text-2xl group-hover:rotate-12 transition-transform\" data-kid=\"153\"></i>\n        </button>\n    </div>\n</div>\n",
      "comments": [],
      "created": "2026-06-03T17:44:23.819306+00:00",
      "modified": "2026-06-03T17:44:23.819306+00:00",
