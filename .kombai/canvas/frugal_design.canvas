      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary: #FF500B;\n    --bg-deep: oklch(0.06 0.025 270);\n    --text-crisp: oklch(0.97 0 0);\n  }\n\n  body {\n    background-color: var(--bg-deep);\n    color: var(--text-crisp);\n    font-family: 'Inter', sans-serif;\n    overflow-x: hidden;\n  }\n\n  .glass-panel {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .glass-panel:hover {\n    background: rgba(255, 255, 255, 0.05);\n    border-color: rgba(255, 255, 255, 0.12);\n  }\n\n  .nav-item-active {\n    background: rgba(255, 80, 11, 0.08);\n    color: var(--primary);\n    border-right: 2px solid var(--primary);\n  }\n\n  .mesh-bg {\n    position: fixed;\n    inset: 0;\n    z-index: -1;\n    overflow: hidden;\n    pointer-events: none;\n  }\n\n  .mesh-orb {\n    position: absolute;\n    filter: blur(120px);\n    border-radius: 9999px;\n    opacity: 0.4;\n  }\n\n  .primary-btn {\n    background: var(--primary);\n    box-shadow: 0 10px 25px -5px rgba(255, 80, 11, 0.3);\n    transition: all 0.2s ease;\n  }\n\n  .primary-btn:hover {\n    box-shadow: 0 15px 30px -5px rgba(255, 80, 11, 0.5);\n    transform: translateY(-1px);\n  }\n\n  /* Custom Chart JS Overrides */\n  #spendChart {\n    filter: drop-shadow(0 0 10px rgba(255, 80, 11, 0.2));\n  }\n</style>\n\n<div class=\"mesh-bg\" data-kid=\"1\">\n  <div class=\"mesh-orb w-[600px] h-[600px] bg-[#FF500B]/20 -top-32 -right-32\" data-kid=\"2\"></div>\n  <div class=\"mesh-orb w-[500px] h-[500px] bg-purple-600/10 bottom-0 -left-20\" data-kid=\"3\"></div>\n</div>\n\n<div class=\"flex min-h-[1200px] w-full items-stretch\" data-kid=\"4\">\n  \n  <aside class=\"w-[280px] border-r border-white/5 flex flex-col p-8 space-y-10 shrink-0\" data-kid=\"5\">\n    <div class=\"flex items-center gap-3 px-2\" data-kid=\"6\">\n      <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#FF500B]/20 to-[#FF500B]/5 flex items-center justify-center border border-[#FF500B]/30 shadow-[0_0_15px_rgba(255,80,11,0.1)]\" data-kid=\"7\">\n        <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"8\"></i>\n      </div>\n      <span class=\"text-xl font-bold tracking-[0.05em] text-white uppercase\" data-kid=\"9\">Frugal</span>\n    </div>\n\n    <nav class=\"flex-1 space-y-1\" data-kid=\"10\">\n      <div class=\"px-3 mb-4\" data-kid=\"11\">\n        <p class=\"text-[10px] font-bold text-white/40 uppercase tracking-[0.2em]\" data-kid=\"12\">Platform</p>\n      </div>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/60 hover:text-white hover:bg-white/5 transition-all nav-item-active group\" data-kid=\"13\">\n        <i class=\"ti ti-layout-dashboard text-xl group-hover:scale-110 transition-transform\" data-kid=\"14\"></i>\n        <span class=\"font-bold text-sm\" data-kid=\"15\">Overview</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/60 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"16\">\n        <i class=\"ti ti-plug text-xl\" data-kid=\"17\"></i>\n        <span class=\"font-semibold text-sm\" data-kid=\"18\">Connections</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/60 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"19\">\n        <i class=\"ti ti-shield-lock text-xl\" data-kid=\"20\"></i>\n        <span class=\"font-semibold text-sm\" data-kid=\"21\">Rules</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/60 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"22\">\n        <i class=\"ti ti-bell-ringing text-xl\" data-kid=\"23\"></i>\n        <span class=\"font-semibold text-sm\" data-kid=\"24\">Alerts</span>\n        <span class=\"ml-auto bg-[#FF500B] text-white text-[10px] px-2 py-0.5 rounded-full font-bold\" data-kid=\"25\">2</span>\n      </a>\n      \n      <div class=\"px-3 mt-10 mb-4\" data-kid=\"26\">\n        <p class=\"text-[10px] font-bold text-white/30 uppercase tracking-[0.2em]\" data-kid=\"27\">Account</p>\n      </div>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/60 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"28\">\n        <i class=\"ti ti-settings text-xl\" data-kid=\"29\"></i>\n        <span class=\"font-semibold text-sm\" data-kid=\"30\">Settings</span>\n      </a>\n    </nav>\n\n    <div class=\"glass-panel p-4 rounded-3xl space-y-4\" data-kid=\"31\">\n      <div class=\"flex items-center gap-3\" data-kid=\"32\">\n        <div class=\"relative\" data-kid=\"33\">\n          <img src=\"https://i.pravatar.cc/100?u=nilesh\" class=\"w-10 h-10 rounded-2xl border border-white/10\" alt=\"Avatar\" data-kid=\"34\">\n          <div class=\"absolute -bottom-1 -right-1 w-3 h-3 bg-emerald-500 rounded-full border-2 border-[var(--bg-deep)]\" data-kid=\"35\"></div>\n        </div>\n        <div class=\"min-w-0\" data-kid=\"36\">\n          <p class=\"text-xs font-bold text-white truncate\" data-kid=\"37\">Nilesh Kumar</p>\n          <p class=\"text-[10px] text-white/40 truncate font-mono\" data-kid=\"38\">FRG_ADMIN_01</p>\n        </div>\n      </div>\n      <button class=\"w-full py-2.5 rounded-xl bg-white/5 text-white/60 text-[10px] font-bold hover:bg-white/10 transition-colors uppercase tracking-widest\" data-kid=\"39\">Sign Out</button>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 p-10 space-y-10 max-w-[1160px]\" data-kid=\"40\">\n    \n    <header class=\"flex justify-between items-center\" data-kid=\"41\">\n      <div class=\"space-y-1\" data-kid=\"42\">\n        <div class=\"flex items-center gap-2 text-white/40 text-xs font-semibold mb-1\" data-kid=\"43\">\n          <span class=\"hover:text-white transition-colors cursor-pointer\" data-kid=\"44\">Main Workspace</span>\n          <i class=\"ti ti-chevron-right text-[10px] text-white/20\" data-kid=\"45\"></i>\n          <span class=\"text-white/80\" data-kid=\"46\">Dashboard</span>\n        </div>\n        <h1 class=\"text-4xl font-['Instrument_Serif'] italic text-white tracking-tight\" data-kid=\"47\">Main Dashboard</h1>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"48\">\n        <div class=\"relative group\" data-kid=\"49\">\n          <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-white/30 group-focus-within:text-white transition-colors\" data-kid=\"50\"></i>\n          <input type=\"text\" placeholder=\"Search resources...\" class=\"bg-white/5 border border-white/10 rounded-2xl py-3 pl-12 pr-6 text-sm text-white w-64 focus:outline-none focus:border-white/20 transition-all\" data-kid=\"51\">\n        </div>\n        <button class=\"primary-btn px-6 py-3 rounded-2xl text-white text-sm font-bold flex items-center gap-2\" data-kid=\"52\">\n          <i class=\"ti ti-plus\" data-kid=\"53\"></i>\n          New Rule\n        </button>\n      </div>\n    </header>\n\n    \n    <section class=\"space-y-6\" data-kid=\"54\">\n      <div class=\"flex justify-between items-end px-2\" data-kid=\"55\">\n        <div class=\"space-y-1\" data-kid=\"56\">\n          <h2 class=\"text-xl font-bold text-white\" data-kid=\"57\">Spend Overview</h2>\n          <p class=\"text-sm text-white/40\" data-kid=\"58\">Real-time daily aggregate across connected AI APIs</p>\n        </div>\n        <div class=\"flex bg-white/5 p-1 rounded-2xl border border-white/5\" data-kid=\"59\">\n          <button class=\"px-5 py-2 rounded-xl bg-white/10 text-white text-xs font-bold border border-white/10\" data-kid=\"60\">Past 14 Days</button>\n          <button class=\"px-5 py-2 rounded-xl text-white/40 text-xs font-bold hover:text-white transition-colors\" data-kid=\"61\">Past 30 Days</button>\n        </div>\n      </div>\n\n      <div class=\"glass-panel rounded-[2.5rem] p-10 relative overflow-hidden group\" data-kid=\"62\">\n        \n        <div class=\"absolute -top-24 -right-24 w-64 h-64 bg-[#FF500B]/5 blur-[80px] rounded-full\" data-kid=\"63\"></div>\n        <div class=\"absolute -bottom-24 -left-24 w-64 h-64 bg-purple-600/5 blur-[80px] rounded-full\" data-kid=\"64\"></div>\n\n        <div class=\"grid grid-cols-4 gap-8 mb-12 relative z-10\" data-kid=\"65\">\n          <div class=\"space-y-3 p-7 rounded-[2rem] bg-white/[0.02] border border-white/[0.05] hover:border-white/10 transition-colors\" data-kid=\"66\">\n            <p class=\"text-[10px] font-bold text-white/40 uppercase tracking-[0.2em]\" data-kid=\"67\">Projected End</p>\n            <span class=\"text-3xl font-bold text-white tracking-tight\" data-kid=\"68\">$4,280.50</span>\n          </div>\n          <div class=\"space-y-3 p-7 rounded-[2rem] bg-white/[0.02] border border-white/[0.05] hover:border-white/10 transition-colors\" data-kid=\"69\">\n            <p class=\"text-[10px] font-bold text-white/40 uppercase tracking-[0.2em]\" data-kid=\"70\">Active Keys</p>\n            <span class=\"text-3xl font-bold text-white tracking-tight\" data-kid=\"71\">14</span>\n          </div>\n          <div class=\"space-y-3 p-7 rounded-[2rem] bg-[#FF500B]/5 border border-[#FF500B]/20 hover:bg-[#FF500B]/10 transition-colors\" data-kid=\"72\">\n            <p class=\"text-[10px] font-bold text-[#FF500B] uppercase tracking-[0.2em]\" data-kid=\"73\">Current Savings</p>\n            <div class=\"flex items-baseline gap-2\" data-kid=\"74\">\n              <span class=\"text-3xl font-bold text-[#FF500B] tracking-tight\" data-kid=\"75\">$342.10</span>\n              <i class=\"ti ti-bolt text-[#FF500B]\" data-kid=\"76\"></i>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"h-[350px] w-full relative z-10\" data-kid=\"77\">\n          <canvas id=\"spendChart\" data-kid=\"78\"></canvas>\n        </div>\n      </div>\n    </section>\n\n    \n    <div class=\"grid grid-cols-12 gap-8\" data-kid=\"79\">\n      \n      \n      <div class=\"col-span-4 glass-panel rounded-[2.5rem] p-8 space-y-8 flex flex-col\" data-kid=\"80\">\n        <div class=\"flex justify-between items-center\" data-kid=\"81\">\n          <h3 class=\"text-lg font-bold text-white\" data-kid=\"82\">Provider Breakdown</h3>\n          <button class=\"w-8 h-8 rounded-full bg-white/5 flex items-center justify-center border border-white/5 hover:bg-white/10 transition-colors\" data-kid=\"83\">\n            <i class=\"ti ti-external-link text-white/40 text-sm\" data-kid=\"84\"></i>\n          </button>\n        </div>\n        \n        <div class=\"flex-1 space-y-6\" data-kid=\"85\">\n          <div class=\"space-y-2\" data-kid=\"86\">\n            <div class=\"flex justify-between text-xs font-bold px-1\" data-kid=\"87\">\n              <div class=\"flex items-center gap-2\" data-kid=\"88\">\n                <i class=\"ti ti-brand-openai text-[#74aa9c]\" data-kid=\"89\"></i>\n                <span class=\"text-white/60\" data-kid=\"90\">OpenAI</span>\n              </div>\n              <span class=\"text-white\" data-kid=\"91\">$1,240.20</span>\n            </div>\n            <div class=\"h-2 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"92\">\n              <div class=\"h-full bg-linear-to-r from-emerald-500 to-emerald-400 w-[65%] rounded-full\" data-kid=\"93\"></div>\n            </div>\n          </div>\n\n          <div class=\"space-y-2\" data-kid=\"94\">\n            <div class=\"flex justify-between text-xs font-bold px-1\" data-kid=\"95\">\n              <div class=\"flex items-center gap-2\" data-kid=\"96\">\n                <i class=\"ti ti-hexagon text-[#d97757]\" data-kid=\"97\"></i>\n                <span class=\"text-white/60\" data-kid=\"98\">Anthropic</span>\n              </div>\n              <span class=\"text-white\" data-kid=\"99\">$420.40</span>\n            </div>\n            <div class=\"h-2 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"100\">\n              <div class=\"h-full bg-linear-to-r from-orange-500 to-orange-400 w-[22%] rounded-full\" data-kid=\"101\"></div>\n            </div>\n          </div>\n\n          <div class=\"space-y-2\" data-kid=\"102\">\n            <div class=\"flex justify-between text-xs font-bold px-1\" data-kid=\"103\">\n              <div class=\"flex items-center gap-2\" data-kid=\"104\">\n                <i class=\"ti ti-brand-google text-[#4285F4]\" data-kid=\"105\"></i>\n                <span class=\"text-white/60\" data-kid=\"106\">Google Cloud</span>\n              </div>\n              <span class=\"text-white\" data-kid=\"107\">$181.50</span>\n            </div>\n            <div class=\"h-2 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"108\">\n              <div class=\"h-full bg-linear-to-r from-blue-500 to-blue-400 w-[13%] rounded-full\" data-kid=\"109\"></div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"pt-6 border-t border-white/5\" data-kid=\"110\">\n          <div class=\"flex items-center gap-2 text-white/30 text-[10px] font-bold uppercase tracking-widest\" data-kid=\"111\">\n            <i class=\"ti ti-clock\" data-kid=\"112\"></i>\n            Syncing every 5 minutes\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"col-span-4 glass-panel rounded-[2.5rem] p-8 flex flex-col justify-between relative overflow-hidden group cursor-default\" data-kid=\"113\">\n        <div class=\"absolute -top-12 -right-12 w-48 h-48 bg-[#FF500B]/5 blur-[60px] rounded-full group-hover:bg-[#FF500B]/10 transition-all duration-700\" data-kid=\"114\"></div>\n        \n        <div class=\"space-y-1 relative z-10\" data-kid=\"115\">\n          <div class=\"flex items-center gap-2\" data-kid=\"116\">\n            <h3 class=\"text-lg font-bold text-white\" data-kid=\"117\">Live Burn Rate</h3>\n            <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"118\"></span>\n          </div>\n          <p class=\"text-[10px] text-white/40 uppercase tracking-[0.2em] font-bold\" data-kid=\"119\">Velocity Tracking</p>\n        </div>\n\n        <div class=\"py-6 relative z-10\" data-kid=\"120\">\n          <div class=\"flex items-end gap-3 mb-2\" data-kid=\"121\">\n            <span class=\"text-7xl font-['Instrument_Serif'] italic text-white leading-none group-hover:text-primary transition-colors duration-500\" data-kid=\"122\">$2.45</span>\n            <span class=\"text-white/40 text-lg mb-2\" data-kid=\"123\">/ hour</span>\n          </div>\n          <div class=\"flex items-center gap-2 text-emerald-400 font-bold text-xs\" data-kid=\"124\">\n            <i class=\"ti ti-trending-down\" data-kid=\"125\"></i>\n            4% lower than yesterday\n          </div>\n        </div>\n\n        <div class=\"p-4 rounded-2xl bg-white/[0.03] border border-white/5 space-y-3 relative z-10\" data-kid=\"126\">\n          <div class=\"flex justify-between text-[10px] font-bold text-white/40 uppercase\" data-kid=\"127\">\n            <span data-kid=\"128\">Daily Budget Status</span>\n            <span data-kid=\"129\">72% Used</span>\n          </div>\n          <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"130\">\n            <div class=\"h-full bg-[#FF500B] w-[72%] rounded-full shadow-[0_0_10px_rgba(255,80,11,0.5)]\" data-kid=\"131\"></div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"col-span-4 glass-panel rounded-[2.5rem] p-8 space-y-6 flex flex-col\" data-kid=\"132\">\n        <div class=\"flex justify-between items-center\" data-kid=\"133\">\n          <h3 class=\"text-lg font-bold text-white\" data-kid=\"134\">High-Cost Users</h3>\n          <span class=\"text-[10px] text-[#FF500B] font-bold tracking-widest cursor-pointer hover:underline uppercase\" data-kid=\"135\">Audit Log</span>\n        </div>\n\n        <div class=\"flex-1 space-y-4\" data-kid=\"136\">\n          <div class=\"flex items-center gap-4 p-3 rounded-2xl hover:bg-white/[0.03] transition-all group\" data-kid=\"137\">\n            <img src=\"https://i.pravatar.cc/100?u=user1\" class=\"w-10 h-10 rounded-xl border border-white/10\" alt data-kid=\"138\">\n            <div class=\"flex-1 min-w-0\" data-kid=\"139\">\n              <p class=\"text-sm font-bold text-white truncate\" data-kid=\"140\">user_2841_alpha</p>\n              <p class=\"text-[10px] text-white/40 font-medium\" data-kid=\"141\">842 tokens • GPT-4o</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"142\">\n              <p class=\"text-sm font-bold text-white\" data-kid=\"143\">$42.10</p>\n              <p class=\"text-[10px] text-emerald-400 font-bold\" data-kid=\"144\">-2%</p>\n            </div>\n          </div>\n\n          <div class=\"flex items-center gap-4 p-3 rounded-2xl hover:bg-white/[0.03] transition-all group\" data-kid=\"145\">\n            <img src=\"https://i.pravatar.cc/100?u=user2\" class=\"w-10 h-10 rounded-xl border border-white/10\" alt data-kid=\"146\">\n            <div class=\"flex-1 min-w-0\" data-kid=\"147\">\n              <p class=\"text-sm font-bold text-white truncate\" data-kid=\"148\">dev_nathan</p>\n              <p class=\"text-[10px] text-white/40 font-medium\" data-kid=\"149\">1,202 tokens • Claude 3.5</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"150\">\n              <p class=\"text-sm font-bold text-white\" data-kid=\"151\">$18.40</p>\n              <p class=\"text-[10px] text-rose-400 font-bold\" data-kid=\"152\">+15%</p>\n            </div>\n          </div>\n\n          <div class=\"flex items-center gap-4 p-3 rounded-2xl hover:bg-white/[0.03] transition-all group\" data-kid=\"153\">\n            <img src=\"https://i.pravatar.cc/100?u=user3\" class=\"w-10 h-10 rounded-xl border border-white/10\" alt data-kid=\"154\">\n            <div class=\"flex-1 min-w-0\" data-kid=\"155\">\n              <p class=\"text-sm font-bold text-white truncate\" data-kid=\"156\">bot_agent_09</p>\n              <p class=\"text-[10px] text-white/40 font-medium\" data-kid=\"157\">45 tokens • Dall-E 3</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"158\">\n              <p class=\"text-sm font-bold text-white\" data-kid=\"159\">$12.00</p>\n              <p class=\"text-[10px] text-white/20 font-bold\" data-kid=\"160\">Stable</p>\n            </div>\n          </div>\n        </div>\n\n        <button class=\"w-full py-4 rounded-2xl bg-white/5 border border-white/5 text-white/60 text-xs font-bold hover:bg-white/10 hover:text-white transition-all\" data-kid=\"161\">\n          View Detailed Analytics\n        </button>\n      </div>\n\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"162\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"163\"></script>\n\n<script data-kid=\"164\">\n  // Chart Implementation\n  const ctx = document.getElementById('spendChart').getContext('2d');\n  \n  const gradient = ctx.createLinearGradient(0, 0, 0, 350);\n  gradient.addColorStop(0, 'rgba(255, 80, 11, 0.15)');\n  gradient.addColorStop(1, 'rgba(255, 80, 11, 0)');\n\n  new Chart(ctx, {\n    type: 'line',\n    data: {\n      labels: ['Jun 01', 'Jun 02', 'Jun 03', 'Jun 04', 'Jun 05', 'Jun 06', 'Jun 07', 'Jun 08', 'Jun 09', 'Jun 10', 'Jun 11', 'Jun 12', 'Jun 13', 'Jun 14'],\n      datasets: [{\n        label: 'Spend ($)',\n        data: [45, 62, 58, 85, 120, 95, 80, 110, 140, 125, 160, 145, 130, 155],\n        borderColor: '#FF500B',\n        borderWidth: 3,\n        pointBackgroundColor: '#FF500B',\n        pointBorderColor: 'rgba(255,255,255,0.1)',\n        pointBorderWidth: 2,\n        pointRadius: 4,\n        pointHoverRadius: 6,\n        tension: 0.4,\n        fill: true,\n        backgroundColor: gradient,\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          backgroundColor: 'rgba(0,0,0,0.8)',\n          titleFont: { family: 'Inter', size: 12, weight: 'bold' },\n          bodyFont: { family: 'Inter', size: 12 },\n          padding: 12,\n          displayColors: false,\n          callbacks: {\n            label: function(context) {\n              return '$' + context.parsed.y.toFixed(2);\n            }\n          }\n        }\n      },\n      scales: {\n        x: {\n          grid: { display: false },\n          ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: 'Inter' } }\n        },\n        y: {\n          beginAtZero: true,\n          grid: { color: 'rgba(255,255,255,0.05)' },\n          ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: 'Inter' } }\n        }\n      }\n    }\n  });\n\n  // Entrance Animations\n  gsap.from(\"aside\", { x: -50, opacity: 0, duration: 1, ease: \"power4.out\" });\n  gsap.from(\"header\", { y: -30, opacity: 0, duration: 1, delay: 0.2, ease: \"power4.out\" });\n  gsap.from(\".glass-panel\", { \n    y: 40, \n    opacity: 0, \n    duration: 1.2, \n    stagger: 0.15, \n    delay: 0.4, \n    ease: \"power4.out\" \n  });\n</script>\n",
