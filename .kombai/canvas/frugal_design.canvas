      "html": "\n<div class=\"relative min-h-[1400px] w-full bg-[oklch(0.06_0.025_270)] text-[oklch(0.97_0_0)] font-sans selection:bg-[#FF500B]/30\" data-kid=\"1\">\n  \n  \n  <div class=\"mesh-bg pointer-events-none\" data-kid=\"2\">\n    <div class=\"mesh-orb mesh-orb-1 opacity-20\" data-kid=\"3\"></div>\n    <div class=\"mesh-orb mesh-orb-2 opacity-15\" data-kid=\"4\"></div>\n    <div class=\"mesh-orb mesh-orb-3 opacity-10\" data-kid=\"5\"></div>\n    <div class=\"absolute top-0 right-0 w-[800px] h-[800px] bg-[#FF500B]/5 blur-[120px] -translate-y-1/2 translate-x-1/2\" data-kid=\"6\"></div>\n  </div>\n\n  <style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-serif { font-family: 'Instrument Serif', serif; }\n    \n    .sidebar-link.active {\n      background: oklch(0.6 0.15 30 / 0.08);\n      color: #FF500B;\n      border-color: #FF500B/20;\n    }\n    \n    .sidebar-link {\n      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    .sidebar-link:hover:not(.active) {\n      background: rgba(255, 255, 255, 0.03);\n      color: white;\n    }\n\n    .legal-content h2 {\n      font-family: 'Instrument Serif', serif;\n      font-size: 3.5rem;\n      font-style: italic;\n      line-height: 1;\n      margin-bottom: 2rem;\n      color: white;\n      letter-spacing: -0.02em;\n    }\n\n    .legal-content h3 {\n      font-weight: 600;\n      color: white;\n      margin-bottom: 0.5rem;\n    }\n\n    .legal-content p {\n      color: oklch(0.97 0 0 / 0.6);\n      line-height: 1.7;\n      font-size: 1.125rem;\n      margin-bottom: 1.5rem;\n    }\n\n    .legal-content ul {\n      margin-bottom: 2rem;\n    }\n\n    .legal-content li {\n      margin-bottom: 1.25rem;\n      color: oklch(0.97 0 0 / 0.6);\n      padding-left: 2rem;\n      position: relative;\n    }\n\n    .legal-content li::before {\n      content: \"\";\n      position: absolute;\n      left: 0;\n      top: 0.75rem;\n      width: 6px;\n      height: 6px;\n      border-radius: 9999px;\n      background-color: #FF500B;\n    }\n\n    .callout-box {\n      background: linear-gradient(135deg, rgba(255, 80, 11, 0.08) 0%, rgba(255, 80, 11, 0.02) 100%);\n      border: 1px solid rgba(255, 80, 11, 0.15);\n      border-radius: 2rem;\n      padding: 3rem;\n      position: relative;\n      overflow: hidden;\n    }\n  </style>\n\n  \n  <header class=\"max-w-7xl mx-auto pt-32 pb-20 px-8 relative z-10\" data-kid=\"7\">\n    <div class=\"inline-flex items-center gap-3 px-4 py-1.5 rounded-full glass-panel border-white/5 mb-10\" data-kid=\"8\">\n      <div class=\"w-2 h-2 rounded-full bg-[#FF500B] animate-pulse\" data-kid=\"9\"></div>\n      <span class=\"text-[10px] font-bold uppercase tracking-[0.25em] text-white/50\" data-kid=\"10\">Compliance Version 1.0</span>\n    </div>\n    <div class=\"flex flex-col lg:flex-row lg:items-end justify-between gap-12\" data-kid=\"11\">\n      <div class=\"max-w-4xl\" data-kid=\"12\">\n        <h1 class=\"text-7xl md:text-[10rem] font-serif italic tracking-tighter leading-[0.85] mb-8\" data-kid=\"13\">\n          Privacy Policy\n        </h1>\n        <p class=\"text-xl md:text-2xl text-white/40 max-w-2xl font-light leading-relaxed\" data-kid=\"14\">\n          Detailing how Frugal handles your sensitive data, API credentials, and provides security-first cost management.\n        </p>\n      </div>\n      <div class=\"flex items-center gap-6 text-[10px] font-bold uppercase tracking-[0.3em] text-white/20 pb-4\" data-kid=\"15\">\n        <span data-kid=\"16\">Effective June 24, 2026</span>\n        <div class=\"w-12 h-px bg-white/10\" data-kid=\"17\"></div>\n        <span data-kid=\"18\">Gray Matter Labs</span>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"max-w-7xl mx-auto px-8 pb-32 relative z-10\" data-kid=\"19\">\n    <div class=\"glass-panel rounded-[3rem] overflow-hidden flex flex-col lg:flex-row min-h-[1000px] border-white/10\" data-kid=\"20\">\n      \n      \n      <aside class=\"lg:w-80 shrink-0 border-b lg:border-b-0 lg:border-r border-white/5 bg-white/[0.01] p-10 lg:p-12\" data-kid=\"21\">\n        <div class=\"sticky top-12\" data-kid=\"22\">\n          <p class=\"text-[10px] font-bold uppercase tracking-[0.3em] text-white/20 mb-8 px-4\" data-kid=\"23\">Sections</p>\n          <nav class=\"flex flex-col gap-1.5\" data-kid=\"24\">\n            <a href=\"#intro\" class=\"sidebar-link active flex items-center gap-4 py-3.5 px-5 rounded-2xl border border-transparent font-medium group\" data-kid=\"25\">\n              <span class=\"text-[10px] font-bold tabular-nums opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"26\">01</span>\n              <span class=\"text-sm\" data-kid=\"27\">Introduction</span>\n            </a>\n            <a href=\"#collection\" class=\"sidebar-link flex items-center gap-4 py-3.5 px-5 rounded-2xl border border-transparent font-medium group text-white/40\" data-kid=\"28\">\n              <span class=\"text-[10px] font-bold tabular-nums opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"29\">02</span>\n              <span class=\"text-sm\" data-kid=\"30\">Data Collection</span>\n            </a>\n            <a href=\"#security\" class=\"sidebar-link flex items-center gap-4 py-3.5 px-5 rounded-2xl border border-transparent font-medium group text-white/40\" data-kid=\"31\">\n              <span class=\"text-[10px] font-bold tabular-nums opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"32\">03</span>\n              <span class=\"text-sm\" data-kid=\"33\">API Key Security</span>\n            </a>\n            <a href=\"#dpdp\" class=\"sidebar-link flex items-center gap-4 py-3.5 px-5 rounded-2xl border border-transparent font-medium group text-white/40\" data-kid=\"34\">\n              <span class=\"text-[10px] font-bold tabular-nums opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"35\">04</span>\n              <span class=\"text-sm\" data-kid=\"36\">DPDP Compliance</span>\n            </a>\n            <a href=\"#gdpr\" class=\"sidebar-link flex items-center gap-4 py-3.5 px-5 rounded-2xl border border-transparent font-medium group text-white/40\" data-kid=\"37\">\n              <span class=\"text-[10px] font-bold tabular-nums opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"38\">05</span>\n              <span class=\"text-sm\" data-kid=\"39\">GDPR Basics</span>\n            </a>\n            <a href=\"#sharing\" class=\"sidebar-link flex items-center gap-4 py-3.5 px-5 rounded-2xl border border-transparent font-medium group text-white/40\" data-kid=\"40\">\n              <span class=\"text-[10px] font-bold tabular-nums opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"41\">06</span>\n              <span class=\"text-sm\" data-kid=\"42\">Third Parties</span>\n            </a>\n            <a href=\"#rights\" class=\"sidebar-link flex items-center gap-4 py-3.5 px-5 rounded-2xl border border-transparent font-medium group text-white/40\" data-kid=\"43\">\n              <span class=\"text-[10px] font-bold tabular-nums opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"44\">07</span>\n              <span class=\"text-sm\" data-kid=\"45\">Your Rights</span>\n            </a>\n          </nav>\n\n          \n          <div class=\"mt-20 p-8 rounded-3xl bg-white/[0.03] border border-white/5\" data-kid=\"46\">\n            <div class=\"w-12 h-12 rounded-2xl bg-[#FF500B]/20 flex items-center justify-center border border-[#FF500B]/30 mb-6 shadow-lg shadow-orange-500/10\" data-kid=\"47\">\n              <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"48\"></i>\n            </div>\n            <h4 class=\"text-lg font-serif italic mb-2 text-white\" data-kid=\"49\">Always Secure</h4>\n            <p class=\"text-sm text-white/40 leading-relaxed font-light\" data-kid=\"50\">\n              Frugal uses industry standard encryption for all sensitive data. Your API keys never leave our secure vault.\n            </p>\n          </div>\n        </div>\n      </aside>\n\n      \n      <article class=\"legal-content flex-1 p-12 lg:p-24 bg-linear-to-br from-white/[0.01] to-transparent\" data-kid=\"51\">\n        \n        <section id=\"intro\" class=\"mb-24\" data-kid=\"52\">\n          <h2 data-kid=\"53\">1. Introduction</h2>\n          <div class=\"space-y-6\" data-kid=\"54\">\n            <p data-kid=\"55\">\n              Welcome to Frugal, an AI API cost management platform operated by Gray Matter Labs (\"we\", \"our\", or \"us\"). Your privacy is paramount. This Privacy Policy outlines how we collect, process, and protect your information when you use our services.\n            </p>\n            <p data-kid=\"56\">\n              By accessing or using Frugal, you agree to the practices described in this policy. We ensure compliance with global standards, including India's Digital Personal Data Protection (DPDP) Act 2023 and the General Data Protection Regulation (GDPR) for EU citizens.\n            </p>\n          </div>\n        </section>\n\n        <section id=\"collection\" class=\"mb-24\" data-kid=\"57\">\n          <h2 data-kid=\"58\">2. Data Collection</h2>\n          <p data-kid=\"59\">\n            We collect only the minimum data necessary to provide a high-quality cost management experience. This includes:\n          </p>\n          <ul class=\"grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2 mt-8\" data-kid=\"60\">\n            <li data-kid=\"61\"><strong data-kid=\"62\">Personal Identity:</strong> Email address used for account creation and communications.</li>\n            <li data-kid=\"63\"><strong data-kid=\"64\">Service Credentials:</strong> API keys for various AI providers (OpenAI, Anthropic, etc.).</li>\n            <li data-kid=\"65\"><strong data-kid=\"66\">Usage Metadata:</strong> Patterns of your API consumption, spend history, and metrics.</li>\n            <li data-kid=\"67\"><strong data-kid=\"68\">Billing Information:</strong> Payment details processed securely via Stripe.</li>\n          </ul>\n        </section>\n\n        \n        <section id=\"security\" class=\"mb-24\" data-kid=\"69\">\n          <div class=\"callout-box group\" data-kid=\"70\">\n            <div class=\"absolute -right-16 -bottom-16 opacity-5 group-hover:scale-110 transition-transform duration-1000 pointer-events-none\" data-kid=\"71\">\n              <i class=\"ti ti-shield-lock text-[20rem] text-[#FF500B]\" data-kid=\"72\"></i>\n            </div>\n            <div class=\"relative z-10\" data-kid=\"73\">\n              <div class=\"flex items-center gap-4 mb-8\" data-kid=\"74\">\n                <div class=\"w-14 h-14 rounded-2xl bg-[#FF500B] flex items-center justify-center shadow-xl shadow-orange-500/30\" data-kid=\"75\">\n                  <i class=\"ti ti-lock text-white text-3xl\" data-kid=\"76\"></i>\n                </div>\n                <h2 class=\"!mb-0\" data-kid=\"77\">3. API Key Security</h2>\n              </div>\n              <p class=\"text-xl md:text-2xl text-white/80 font-light leading-relaxed max-w-3xl mb-0\" data-kid=\"78\">\n                Your API keys are the lifeblood of your operations. <strong class=\"text-white font-semibold\" data-kid=\"79\">All API keys are encrypted at rest using AES-256 standards</strong> before being stored in our secure database. Access is strictly limited to automated monitoring agents and never exposed in plain text to any human staff.\n              </p>\n            </div>\n          </div>\n        </section>\n\n        <section id=\"dpdp\" class=\"mb-24\" data-kid=\"80\">\n          <h2 data-kid=\"81\">4. DPDP Compliance</h2>\n          <p data-kid=\"82\">\n            In accordance with India's Digital Personal Data Protection Act 2023, Frugal acts as a \"Data Fiduciary\" for our Indian users.\n          </p>\n          <ul class=\"space-y-4 mt-8\" data-kid=\"83\">\n            <li data-kid=\"84\"><strong data-kid=\"85\">Explicit Consent:</strong> Clear, affirmative consent before processing personal data.</li>\n            <li data-kid=\"86\"><strong data-kid=\"87\">Data Portability:</strong> Users may request a download of all associated data.</li>\n            <li data-kid=\"88\"><strong data-kid=\"89\">Right to Erasure:</strong> Permanent deletion of account and data at any time.</li>\n            <li data-kid=\"90\"><strong data-kid=\"91\">Grievance Redressal:</strong> Direct access to our Data Protection Officer.</li>\n          </ul>\n        </section>\n\n        <section id=\"gdpr\" class=\"mb-24\" data-kid=\"92\">\n          <h2 data-kid=\"93\">5. GDPR Basics</h2>\n          <p data-kid=\"94\">\n            For our users in the European Economic Area (EEA), we process personal data under the following lawful bases:\n          </p>\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 my-10\" data-kid=\"95\">\n            <div class=\"p-8 rounded-3xl bg-white/[0.03] border border-white/5\" data-kid=\"96\">\n              <h4 class=\"font-bold text-white mb-3\" data-kid=\"97\">Necessity</h4>\n              <p class=\"text-sm text-white/40 mb-0\" data-kid=\"98\">Processing required to provide the core service.</p>\n            </div>\n            <div class=\"p-8 rounded-3xl bg-white/[0.03] border border-white/5\" data-kid=\"99\">\n              <h4 class=\"font-bold text-white mb-3\" data-kid=\"100\">Interest</h4>\n              <p class=\"text-sm text-white/40 mb-0\" data-kid=\"101\">Improving platform security and operational efficiency.</p>\n            </div>\n            <div class=\"p-8 rounded-3xl bg-white/[0.03] border border-white/5\" data-kid=\"102\">\n              <h4 class=\"font-bold text-white mb-3\" data-kid=\"103\">Consent</h4>\n              <p class=\"text-sm text-white/40 mb-0\" data-kid=\"104\">For communications and non-essential cookie usage.</p>\n            </div>\n          </div>\n          <p data-kid=\"105\">\n            We store EU user data in dedicated EU regions (Supabase Frankfurt) to ensure maximum compliance and performance.\n          </p>\n        </section>\n\n        <section id=\"sharing\" class=\"mb-24\" data-kid=\"106\">\n          <h2 data-kid=\"107\">6. Third Parties</h2>\n          <p data-kid=\"108\">\n            We do not sell your data. We only share information with trusted third-party service providers essential for our operations:\n          </p>\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 my-10\" data-kid=\"109\">\n            <div class=\"group p-8 rounded-3xl bg-white/[0.03] border border-white/5 hover:bg-white/[0.06] transition-all\" data-kid=\"110\">\n              <div class=\"flex items-center justify-between mb-6\" data-kid=\"111\">\n                <i class=\"ti ti-credit-card text-[#FF500B] text-2xl\" data-kid=\"112\"></i>\n                <span class=\"text-[10px] font-bold uppercase tracking-widest text-white/20\" data-kid=\"113\">Payments</span>\n              </div>\n              <h3 class=\"text-xl font-bold text-white mb-2\" data-kid=\"114\">Stripe</h3>\n              <p class=\"text-sm text-white/40 mb-0\" data-kid=\"115\">Global standard for secure payment processing and tax compliance management.</p>\n            </div>\n            <div class=\"group p-8 rounded-3xl bg-white/[0.03] border border-white/5 hover:bg-white/[0.06] transition-all\" data-kid=\"116\">\n              <div class=\"flex items-center justify-between mb-6\" data-kid=\"117\">\n                <i class=\"ti ti-mail text-[#FF500B] text-2xl\" data-kid=\"118\"></i>\n                <span class=\"text-[10px] font-bold uppercase tracking-widest text-white/20\" data-kid=\"119\">Communications</span>\n              </div>\n              <h3 class=\"text-xl font-bold text-white mb-2\" data-kid=\"120\">Resend</h3>\n              <p class=\"text-sm text-white/40 mb-0\" data-kid=\"121\">Transactional email delivery for account security and operational notifications.</p>\n            </div>\n          </div>\n        </section>\n\n        <section id=\"rights\" class=\"mb-24\" data-kid=\"122\">\n          <h2 data-kid=\"123\">7. Your Rights</h2>\n          <p data-kid=\"124\">\n            Regardless of your location, we provide all users with robust tools to manage their privacy. You have the right to access, correct, delete, or opt-out of data processing at any time through your workspace settings.\n          </p>\n          <div class=\"mt-12 p-12 rounded-[2.5rem] glass-panel text-center relative overflow-hidden group border-orange-500/10\" data-kid=\"125\">\n            <div class=\"absolute inset-0 bg-linear-to-b from-[#FF500B]/5 to-transparent pointer-events-none\" data-kid=\"126\"></div>\n            <p class=\"text-[10px] font-bold uppercase tracking-[0.4em] text-white/30 mb-6\" data-kid=\"127\">Privacy Concierge</p>\n            <p class=\"text-4xl md:text-5xl font-serif italic text-white mb-10\" data-kid=\"128\">privacy@frugal.ai</p>\n            <div class=\"flex flex-col md:flex-row items-center justify-center gap-6\" data-kid=\"129\">\n              <a href=\"mailto:privacy@frugal.ai\" class=\"px-10 py-4 rounded-2xl bg-[#FF500B] text-white font-bold text-lg hover:shadow-[0_10px_40px_rgba(255,80,11,0.3)] hover:-translate-y-1 transition-all\" data-kid=\"130\">\n                Contact Privacy Team\n              </a>\n              <a href=\"#\" class=\"px-10 py-4 rounded-2xl bg-white/5 border border-white/10 text-white font-bold text-lg hover:bg-white/10 transition-all\" data-kid=\"131\">\n                Download Data Export\n              </a>\n            </div>\n          </div>\n        </section>\n\n      </article>\n\n    </div>\n  </main>\n\n  \n  <footer class=\"max-w-7xl mx-auto px-8 pb-20 relative z-10\" data-kid=\"132\">\n    <div class=\"pt-20 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-10\" data-kid=\"133\">\n      <div class=\"flex items-center gap-4\" data-kid=\"134\">\n        <div class=\"w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center border border-white/10\" data-kid=\"135\">\n          <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"136\"></i>\n        </div>\n        <span class=\"font-serif italic text-3xl tracking-tight text-white\" data-kid=\"137\">Frugal.ai</span>\n      </div>\n      <p class=\"text-sm text-white/20 font-medium\" data-kid=\"138\">© 2026 Gray Matter Labs. Built for financial sovereignty.</p>\n      <div class=\"flex gap-10\" data-kid=\"139\">\n        <a href=\"#\" class=\"text-sm text-white/40 hover:text-[#FF500B] transition-colors\" data-kid=\"140\">Terms of Service</a>\n        <a href=\"#\" class=\"text-sm text-white/40 hover:text-[#FF500B] transition-colors\" data-kid=\"141\">Cookie Policy</a>\n        <a href=\"#\" class=\"text-sm text-white/40 hover:text-[#FF500B] transition-colors\" data-kid=\"142\">Security Portal</a>\n      </div>\n    </div>\n  </footer>\n</div>\n",
