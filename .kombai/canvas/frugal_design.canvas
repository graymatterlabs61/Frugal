      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --primary: #FF500B;\n        --bg-deep: oklch(0.06 0.025 270);\n        --text-crisp: oklch(0.97 0 0);\n    }\n\n    body {\n        margin: 0;\n        padding: 0;\n        background-color: var(--bg-deep);\n        color: var(--text-crisp);\n        font-family: 'Inter', sans-serif;\n    }\n\n    .mesh-gradient {\n        background: radial-gradient(at 10% 10%, var(--bg-deep) 0%, transparent 60%),\n                    radial-gradient(at 90% 10%, rgba(255, 80, 11, 0.12) 0%, transparent 50%),\n                    radial-gradient(at 90% 90%, var(--bg-deep) 0%, transparent 60%),\n                    radial-gradient(at 10% 90%, rgba(147, 51, 234, 0.08) 0%, transparent 60%);\n    }\n\n    .glass-panel {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(24px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    .alert-card {\n        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    .alert-card:hover {\n        background: rgba(255, 255, 255, 0.05);\n        border-color: rgba(255, 80, 11, 0.25);\n        transform: translateX(4px);\n    }\n\n    .sidebar-link {\n        transition: all 0.2s ease;\n    }\n\n    .sidebar-link.active {\n        background: rgba(255, 80, 11, 0.05);\n        color: white;\n        border: 1px solid rgba(255, 80, 11, 0.15);\n        box-shadow: inset 0 0 15px rgba(255, 80, 11, 0.05);\n    }\n\n    .sidebar-link.active i {\n        color: var(--primary);\n        filter: drop-shadow(0 0 8px rgba(255, 80, 11, 0.4));\n    }\n\n    .stat-card-hover:hover {\n        background: rgba(255, 255, 255, 0.06);\n        border-color: rgba(255, 255, 255, 0.2);\n        transform: translateY(-2px);\n    }\n\n    .badge {\n        display: inline-flex;\n        align-items: center;\n        gap: 0.375rem;\n        padding: 0.375rem 0.75rem;\n        border-radius: 0.625rem;\n        font-size: 0.7rem;\n        font-weight: 700;\n        text-transform: uppercase;\n        letter-spacing: 0.05em;\n    }\n\n    .badge-warning {\n        background: rgba(255, 80, 11, 0.15);\n        border: 1px solid rgba(255, 80, 11, 0.3);\n        color: #FF7033;\n    }\n\n    .badge-success {\n        background: rgba(16, 185, 129, 0.1);\n        border: 1px solid rgba(16, 185, 129, 0.2);\n        color: #10b981;\n    }\n\n    .badge-neutral {\n        background: rgba(255, 255, 255, 0.08);\n        border: 1px solid rgba(255, 255, 255, 0.15);\n        color: rgba(255, 255, 255, 0.7);\n    }\n\n    /* Scrollbar */\n    ::-webkit-scrollbar {\n        width: 6px;\n    }\n    ::-webkit-scrollbar-track {\n        background: transparent;\n    }\n    ::-webkit-scrollbar-thumb {\n        background: rgba(255, 255, 255, 0.05);\n        border-radius: 10px;\n    }\n    ::-webkit-scrollbar-thumb:hover {\n        background: rgba(255, 255, 255, 0.1);\n    }\n</style>\n\n<div class=\"flex min-h-[900px] w-full mesh-gradient relative\" data-kid=\"1\">\n    \n    \n    <aside class=\"w-[280px] shrink-0 border-r border-white/5 flex flex-col p-8 glass-panel relative z-20\" data-kid=\"2\">\n        \n        <div class=\"flex items-center gap-3 mb-16\" data-kid=\"3\">\n            <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#FF500B]/20 to-[#FF500B]/5 flex items-center justify-center border border-[#FF500B]/30 shadow-[0_0_15px_rgba(255,80,11,0.1)]\" data-kid=\"4\">\n                <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"5\"></i>\n            </div>\n            <span class=\"text-xl font-bold tracking-[0.05em] uppercase\" data-kid=\"6\">Frugal</span>\n        </div>\n\n        \n        <nav class=\"flex-1 space-y-2\" data-kid=\"7\">\n            <p class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.2em] mb-4 ml-4\" data-kid=\"8\">Main Menu</p>\n            \n            <a href=\"#\" class=\"sidebar-link flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/40 hover:text-white\" data-kid=\"9\">\n                <i class=\"ti ti-layout-dashboard text-xl\" data-kid=\"10\"></i>\n                <span class=\"font-semibold\" data-kid=\"11\">Dashboard</span>\n            </a>\n            \n            <a href=\"#\" class=\"sidebar-link active flex items-center gap-3 px-4 py-3.5 rounded-2xl\" data-kid=\"12\">\n                <i class=\"ti ti-bell-ringing text-xl\" data-kid=\"13\"></i>\n                <span class=\"font-semibold\" data-kid=\"14\">Alert Log</span>\n            </a>\n            \n            <a href=\"#\" class=\"sidebar-link flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/40 hover:text-white\" data-kid=\"15\">\n                <i class=\"ti ti-wallet text-xl\" data-kid=\"16\"></i>\n                <span class=\"font-semibold\" data-kid=\"17\">Spending</span>\n            </a>\n            \n            <a href=\"#\" class=\"sidebar-link flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/40 hover:text-white\" data-kid=\"18\">\n                <i class=\"ti ti-chart-dots text-xl\" data-kid=\"19\"></i>\n                <span class=\"font-semibold\" data-kid=\"20\">Optimization</span>\n            </a>\n\n            <div class=\"pt-8\" data-kid=\"21\">\n                <p class=\"text-[10px] font-bold text-white/20 uppercase tracking-[0.2em] mb-4 ml-4\" data-kid=\"22\">Organization</p>\n                <a href=\"#\" class=\"sidebar-link flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white/40 hover:text-white\" data-kid=\"23\">\n                    <i class=\"ti ti-users text-xl\" data-kid=\"24\"></i>\n                    <span class=\"font-semibold\" data-kid=\"25\">Team Members</span>\n                </a>\n                <a href=\"#\" class=\"sidebar-link flex