    },
    "var_8962debb0a4c": {
      "type": "variant",
      "label": "Main Dashboard",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 16940,
        "y": 0,
        "w": 1440,
        "h": 1313
