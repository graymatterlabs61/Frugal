      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --primary: #FF500B;\n        --bg-deep: oklch(0.06 0.025 270);\n        --text-crisp: oklch(0.97 0 0);\n    }\n\n    body {\n        margin: 0;\n        padding: 0;\n        background-color: var(--bg-deep);\n        color: var(--text-crisp);\n        font-family: 'Inter', sans-serif;\n    }\n\n    .mesh-gradient {\n        background: radial-gradient(at 10% 10%, var(--bg-deep) 0%, transparent 60%),\n                    radial-gradient(at 90% 10%, rgba(255, 80, 11, 0.15) 0%, transparent 60%),\n                    radial-gradient(at 90% 90%, var(--bg-deep) 0%, transparent 60%),\n                    radial-gradient(at 10% 90%, rgba(147, 51, 234, 0.1) 0%, transparent 60%);\n    }\n\n    .mesh-orb {\n        position: absolute;\n        filter: blur(120px);\n        border-radius: 9999px;\n        z-index: 1;\n        opacity: 0.6;\n    }\n\n    .glass-panel {\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(24px);\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);\n    }\n\n    .input-field {\n        background: rgba(255, 255, 255, 0.04);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n        transition: all 0.2s ease;\n    }\n\n    .input-field:focus {\n        border-color: var(--primary);\n        background: rgba(255, 255, 255, 0.06);\n        outline: none;\n        box-shadow: 0 0 0 2px rgba(255, 80, 11, 0.2);\n    }\n\n    .primary-btn {\n        background: var(--primary);\n        box-shadow: 0 10px 25px -5px rgba(255, 80, 11, 0.4);\n        transition: all 0.2s ease;\n    }\n\n    .primary-btn:hover {\n        box-shadow: 0 15px 30px -5px rgba(255, 80, 11, 0.6);\n        transform: translateY(-1px);\n    }\n\n    .primary-btn:active {\n        transform: translateY(0);\n    }\n\n    @keyframes float {\n        0%, 100% { transform: translateY(0) rotate(-2deg); }\n        50% { transform: translateY(-15px) rotate(-1deg); }\n    }\n\n    .animate-float {\n        animation: float 6s ease-in-out infinite;\n    }\n    .animate-float-delayed {\n        animation: float 7s ease-in-out infinite;\n        animation-delay: 1s;\n    }\n</style>\n\n<div class=\"flex min-h-[900px] w-full\" data-kid=\"1\">\n    \n    <section class=\"w-1/2 flex flex-col items-center justify-center p-8 lg:p-16 z-10 bg-[var(--bg-deep)]\" data-kid=\"2\">\n        <div class=\"w-full max-w-[420px] space-y-10\" data-kid=\"3\">\n            \n            <div class=\"flex items-center gap-3\" data-kid=\"4\">\n                <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#FF500B]/20 to-[#FF500B]/5 flex items-center justify-center border border-[#FF500B]/30 shadow-[0_0_15px_rgba(255,80,11,0.1)]\" data-kid=\"5\">\n                    <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"6\"></i>\n                </div>\n                <span class=\"text-xl font-bold tracking-[0.05em] text-[var(--text-crisp)] uppercase\" data-kid=\"7\">Frugal</span>\n            </div>\n\n            \n            <div class=\"space-y-4\" data-kid=\"8\">\n                <h1 class=\"text-6xl font-['Instrument_Serif'] tracking-tighter leading-[0.9] italic text-white\" data-kid=\"9\">Welcome back</h1>\n                <p class=\"text-[oklch(0.97_0_0/0.6)] text-lg max-w-[340px]\" data-kid=\"10\">Enter your credentials to access your Frugal workspace.</p>\n            </div>\n\n            \n            <form class=\"space-y-7\" data-kid=\"11\">\n                <div class=\"space-y-5\" data-kid=\"12\">\n                    <div class=\"space-y-2.5\" data-kid=\"13\">\n                        <label for=\"email\" class=\"text-sm font-semibold text-white/90 ml-1 tracking-wide\" data-kid=\"14\">Work Email</label>\n                        <input type=\"email\" id=\"email\" placeholder=\"alex@company.com\" class=\"w-full px-5 py-4 rounded-2xl input-field text-white placeholder:text-white/25\" data-kid=\"15\">\n                    </div>\n                    <div class=\"space-y-2.5 relative\" data-kid=\"16\">\n                        <div class=\"flex justify-between items-center ml-1\" data-kid=\"17\">\n                            <label for=\"password\" class=\"text-sm font-semibold text-white/90 tracking-wide\" data-kid=\"18\">Password</label>\n                            <a href=\"#\" class=\"text-sm font-semibold text-[#FF500B] hover:text-[#ff7a45] transition-colors\" data-kid=\"19\">Forgot password?</a>\n                        </div>\n                        <input type=\"password\" id=\"password\" placeholder=\"••••••••••••\" class=\"w-full px-5 py-4 rounded-2xl input-field text-white placeholder:text-white/25\" data-kid=\"20\">\n                    </div>\n                </div>\n\n                <div class=\"flex items-center gap-3 ml-1 group/check\" data-kid=\"21\">\n                    <div class=\"relative flex items-center\" data-kid=\"22\">\n                        <input type=\"checkbox\" id=\"remember\" class=\"peer appearance-none w-6 h-6 rounded-lg border border-white/20 bg-white/5 cursor-pointer transition-all checked:bg-[#FF500B] checked:border-[#FF500B]\" data-kid=\"23\">\n                        <i class=\"ti ti-check absolute left-1 text-white scale-0 peer-checked:scale-100 transition-transform pointer-events-none text-sm\" data-kid=\"24\"></i>\n                    </div>\n                    <label for=\"remember\" class=\"text-sm text-white/60 cursor-pointer select-none font-medium group-hover/check:text-white/80 transition-colors\" data-kid=\"25\">Keep me signed in for 30 days</label>\n                </div>\n\n                <button type=\"submit\" class=\"w-full py-4.5 rounded-2xl primary-btn text-white font-bold text-lg cursor-pointer active:scale-[0.96] transition-all flex items-center justify-center gap-2 group\" data-kid=\"26\">\n                    Access Dashboard\n                    <i class=\"ti ti-arrow-right text-white/50 group-hover:translate-x-1 transition-transform\" data-kid=\"27\"></i>\n                </button>\n            </form>\n\n            \n            <div class=\"space-y-10 pt-4\" data-kid=\"28\">\n                <div class=\"relative\" data-kid=\"29\">\n                    <div class=\"absolute inset-0 flex items-center\" data-kid=\"30\"><div class=\"w-full border-t border-white/15\" data-kid=\"31\"></div></div>\n                    <div class=\"relative flex justify-center text-[10px] uppercase tracking-[0.5em] font-bold\" data-kid=\"32\"><span class=\"bg-[var(--bg-deep)] px-10 text-white/30\" data-kid=\"33\">Network Partners</span></div>\n                </div>\n\n                <div class=\"grid grid-cols-2 gap-4\" data-kid=\"34\">\n                    <button class=\"flex items-center justify-center gap-3 py-4 px-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all cursor-pointer group\" data-kid=\"35\">\n                        <i class=\"ti ti-brand-google text-white/50 group-hover:text-white transition-colors text-xl\" data-kid=\"36\"></i>\n                        <span class=\"text-sm font-bold text-white/80 group-hover:text-white transition-colors\" data-kid=\"37\">Google Workspace</span>\n                    </button>\n                    <button class=\"flex items-center justify-center gap-3 py-4 px-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all cursor-pointer group\" data-kid=\"38\">\n                        <i class=\"ti ti-brand-github text-white/50 group-hover:text-white transition-colors text-xl\" data-kid=\"39\"></i>\n                        <span class=\"text-sm font-bold text-white/80 group-hover:text-white transition-colors\" data-kid=\"40\">Enterprise GitHub</span>\n                    </button>\n                </div>\n            </div>\n\n            \n            <p class=\"text-center text-sm text-white/40\" data-kid=\"41\">\n                New to Frugal? <a href=\"#\" class=\"text-white hover:text-[#FF500B] font-medium underline underline-offset-4 decoration-white/20 hover:decoration-[#FF500B]/50 transition-all\" data-kid=\"42\">Request invite code</a>\n            </p>\n        </div>\n    </section>\n\n    \n    <section class=\"w-1/2 relative flex items-center justify-center overflow-hidden bg-[var(--bg-deep)] border-l border-white/5\" data-kid=\"43\">\n        \n        <div class=\"absolute inset-0 z-0\" data-kid=\"44\">\n            <img src=\"https://images.unsplash.com/photo-1698847179188-b2c6ac026a71?auto=format&w=1200&q=80&fit=crop\" alt=\"Abstract background\" class=\"w-full h-full object-cover opacity-30 mix-blend-luminosity\" decoding=\"async\" loading=\"lazy\" data-kid=\"45\">\n            <div class=\"absolute inset-0 bg-[var(--bg-deep)]/60\" data-kid=\"46\"></div>\n        </div>\n\n        \n        <div class=\"absolute inset-0 mesh-gradient pointer-events-none\" data-kid=\"47\">\n            <div class=\"mesh-orb w-[600px] h-[600px] bg-[#FF500B]/30 -top-32 -right-32 animate-pulse\" data-kid=\"48\"></div>\n            <div class=\"mesh-orb w-[500px] h-[500px] bg-purple-600/15 bottom-0 -left-20\" style=\"animation-delay: 1s\" data-kid=\"49\"></div>\n            <div class=\"mesh-orb w-[400px] h-[400px] bg-blue-500/10 top-1/2 left-1/4\" style=\"animation-delay: 2s\" data-kid=\"50\"></div>\n        </div>\n\n        \n        <div class=\"relative z-10 w-full max-w-[480px] animate-float px-6\" data-kid=\"51\">\n            <div class=\"glass-panel rounded-3xl p-10 space-y-8\" data-kid=\"52\">\n                <div class=\"flex items-center justify-between\" data-kid=\"53\">\n                    <div class=\"space-y-1\" data-kid=\"54\">\n                        <h3 class=\"text-xl font-semibold text-white\" data-kid=\"55\">Spend Over Time</h3>\n                        <div class=\"flex items-center gap-2\" data-kid=\"56\">\n                            <span class=\"w-2 h-2 rounded-full bg-[#FF500B] animate-pulse\" data-kid=\"57\"></span>\n                            <span class=\"text-white/40 text-sm\" data-kid=\"58\">Live cloud API monitoring</span>\n                        </div>\n                    </div>\n                    <div class=\"flex flex-col items-end\" data-kid=\"59\">\n                        <div class=\"px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-lg text-xs font-bold flex items-center gap-1.5\" data-kid=\"60\">\n                            <i class=\"ti ti-trending-down\" data-kid=\"61\"></i>\n                            12.4% DECREASE\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"h-56 flex items-end gap-3 pb-2 border-b border-white/10\" data-kid=\"62\">\n                    <div class=\"flex-1 bg-linear-to-t from-white/5 to-white/10 rounded-t-xl h-[35%] group relative hover:from-white/10 hover:to-white/20 transition-all\" data-kid=\"63\">\n                        <div class=\"absolute -top-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity text-[10px] text-white/60\" data-kid=\"64\">$420</div>\n                    </div>\n                    <div class=\"flex-1 bg-linear-to-t from-white/5 to-white/10 rounded-t-xl h-[55%] group relative hover:from-white/10 hover:to-white/20 transition-all\" data-kid=\"65\">\n                        <div class=\"absolute -top-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity text-[10px] text-white/60\" data-kid=\"66\">$680</div>\n                    </div>\n                    <div class=\"flex-1 bg-white/5 rounded-t-xl h-[45%] group relative hover:bg-white/10 transition-colors\" data-kid=\"67\"></div>\n                    <div class=\"flex-1 bg-white/5 rounded-t-xl h-[85%] group relative hover:bg-white/10 transition-colors\" data-kid=\"68\"></div>\n                    <div class=\"flex-1 bg-[#FF500B] rounded-t-xl h-[65%] shadow-[0_0_30px_rgba(255,80,11,0.4)] relative group\" data-kid=\"69\">\n                        <div class=\"absolute -top-10 left-1/2 -translate-x-1/2 bg-[#FF500B] text-white text-[10px] px-2 py-1 rounded font-bold shadow-lg\" data-kid=\"70\">PEAK</div>\n                    </div>\n                    <div class=\"flex-1 bg-white/5 rounded-t-xl h-[40%] group relative hover:bg-white/10 transition-colors\" data-kid=\"71\"></div>\n                    <div class=\"flex-1 bg-white/5 rounded-t-xl h-[75%] group relative hover:bg-white/10 transition-colors\" data-kid=\"72\"></div>\n                    <div class=\"flex-1 bg-white/5 rounded-t-xl h-[50%] group relative hover:bg-white/10 transition-colors\" data-kid=\"73\"></div>\n                    <div class=\"flex-1 bg-white/5 rounded-t-xl h-[60%] group relative hover:bg-white/10 transition-colors\" data-kid=\"74\"></div>\n                </div>\n\n                \n                <div class=\"grid grid-cols-3 gap-6\" data-kid=\"75\">\n                    <div class=\"space-y-1\" data-kid=\"76\">\n                        <p class=\"text-[10px] font-bold text-white/30 uppercase tracking-[0.2em]\" data-kid=\"77\">Projected</p>\n                        <p class=\"text-lg font-bold text-white tracking-tight\" data-kid=\"78\">$1,420</p>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"79\">\n                        <p class=\"text-[10px] font-bold text-white/30 uppercase tracking-[0.2em]\" data-kid=\"80\">Current</p>\n                        <p class=\"text-lg font-bold text-white tracking-tight\" data-kid=\"81\">$842.10</p>\n                    </div>\n                    <div class=\"space-y-1\" data-kid=\"82\">\n                        <p class=\"text-[10px] font-bold text-[#FF500B] uppercase tracking-[0.2em]\" data-kid=\"83\">Efficiency</p>\n                        <p class=\"text-lg font-bold text-[#FF500B] tracking-tight\" data-kid=\"84\">+24.5%</p>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"absolute -bottom-10 -right-8 glass-panel p-5 rounded-2xl flex items-center gap-4 z-20 border-white/10 animate-float-delayed\" data-kid=\"85\">\n                <div class=\"w-12 h-12 rounded-full bg-linear-to-tr from-[#FF500B] to-[#ff8c00] flex items-center justify-center shadow-[0_0_20px_rgba(255,80,11,0.4)]\" data-kid=\"86\">\n                    <i class=\"ti ti-shield-check text-white text-2xl\" data-kid=\"87\"></i>\n                </div>\n                <div data-kid=\"88\">\n                    <p class=\"text-white text-sm font-bold\" data-kid=\"89\">Cost Guard Active</p>\n                    <p class=\"text-white/40 text-xs\" data-kid=\"90\">Auto-throttling 4 keys</p>\n                </div>\n            </div>\n\n            \n            <div class=\"absolute -top-20 -left-16 w-40 h-40 glass-panel rounded-full flex items-center justify-center p-4 blur-xs opacity-40 z-0 border-white/5\" data-kid=\"91\">\n                <div class=\"w-full h-full rounded-full border border-dashed border-white/30 animate-spin-slow\" data-kid=\"92\"></div>\n            </div>\n        </div>\n    \n        \n        <div class=\"absolute bottom-12 left-12 right-12 flex justify-between items-end opacity-30 pointer-events-none\" data-kid=\"93\">\n            <div class=\"space-y-2\" data-kid=\"94\">\n                <p class=\"text-xs font-mono\" data-kid=\"95\">FRG_SYS_ALPHA_92</p>\n                <p class=\"text-[8px] font-mono leading-none\" data-kid=\"96\">NODE_REDUNDANCY: ACTIVE<br data-kid=\"97\">ENCRYPTION: AES-256-GCM<br data-kid=\"98\">REGION: US-EAST-1</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"99\">\n                <p class=\"text-5xl font-['Instrument_Serif'] leading-none italic\" data-kid=\"100\">Frugal</p>\n            </div>\n        </div>\n    </section>\n</div>\n\n<style data-kid=\"101\">\n    .animate-spin-slow {\n        animation: spin 12s linear infinite;\n    }\n    @keyframes spin {\n        from { transform: rotate(0deg); }\n        to { transform: rotate(360deg); }\n    }\n</style>\n",
