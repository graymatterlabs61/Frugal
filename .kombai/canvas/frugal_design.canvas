      "html": "<div class=\"flex flex-col lg:flex-row w-full min-h-[900px] bg-[oklch(0.06_0.025_270)] font-sans text-[oklch(0.97_0_0)]\" data-kid=\"root\">\n    <style data-kid=\"0\">\n        @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --primary: #FF500B;\n            --bg-deep: oklch(0.06 0.025 270);\n            --text-crisp: oklch(0.97 0 0);\n        }\n\n        .font-serif { font-family: 'Instrument Serif', serif; }\n        .font-sans { font-family: 'Inter', sans-serif; }\n\n        .mesh-gradient {\n            background: radial-gradient(at 10% 10%, var(--bg-deep) 0%, transparent 60%),\n                        radial-gradient(at 90% 10%, rgba(255, 80, 11, 0.12) 0%, transparent 60%),\n                        radial-gradient(at 90% 90%, var(--bg-deep) 0%, transparent 60%),\n                        radial-gradient(at 10% 90%, rgba(147, 51, 234, 0.08) 0%, transparent 60%);\n        }\n\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.03);\n            backdrop-filter: blur(24px);\n            -webkit-backdrop-filter: blur(24px);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);\n        }\n\n        .input-field {\n            background: rgba(255, 255, 255, 0.04);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .input-field:focus {\n            border-color: var(--primary);\n            background: rgba(255, 255, 255, 0.07);\n            outline: none;\n            box-shadow: 0 0 0 1px var(--primary), 0 0 20px rgba(255, 80, 11, 0.15);\n        }\n\n        .primary-btn {\n            background: var(--primary);\n            box-shadow: 0 10px 25px -5px rgba(255, 80, 11, 0.4);\n            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .primary-btn:hover {\n            box-shadow: 0 15px 30px -5px rgba(255, 80, 11, 0.6);\n            transform: translateY(-2px);\n            background: #FF6A31;\n        }\n\n        .primary-btn:active {\n            transform: translateY(0);\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0) rotate(-1deg); }\n            50% { transform: translateY(-15px) rotate(0.5deg); }\n        }\n\n        .animate-float {\n            animation: float 8s ease-in-out infinite;\n        }\n\n        .animate-float-slow {\n            animation: float 12s ease-in-out infinite;\n            animation-delay: -2s;\n        }\n    </style>\n\n    \n    <section class=\"w-full lg:w-1/2 flex flex-col items-center justify-center p-8 lg:p-16 min-h-[900px] z-10 bg-[var(--bg-deep)]\" data-kid=\"1\">\n        <div class=\"w-full max-w-[420px] space-y-10\" data-kid=\"2\">\n            \n            \n            <div class=\"flex items-center gap-3\" data-kid=\"3\">\n                <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#FF500B]/20 to-[#FF500B]/5 flex items-center justify-center border border-[#FF500B]/30 shadow-[0_0_15px_rgba(255,80,11,0.1)]\" data-kid=\"4\">\n                    <i class=\"ti ti-activity text-[#FF500B] text-2xl\" data-kid=\"5\"></i>\n                </div>\n                <span class=\"text-xl font-bold tracking-[0.05em] text-white uppercase italic\" data-kid=\"6\">Frugal</span>\n            </div>\n\n            \n            <div class=\"space-y-4\" data-kid=\"7\">\n                <h1 class=\"text-6xl font-serif tracking-tighter leading-[0.9] italic text-white\" data-kid=\"8\">Create account</h1>\n                <p class=\"text-white/60 text-lg max-w-[340px]\" data-kid=\"9\">Join 4k+ developers mastering their cloud API costs.</p>\n            </div>\n\n            \n            <form class=\"space-y-7\" data-kid=\"10\">\n                <div class=\"space-y-5\" data-kid=\"11\">\n                    \n                    <div class=\"space-y-2.5\" data-kid=\"12\">\n                        <label for=\"name\" class=\"text-sm font-semibold text-white/90 ml-1 tracking-wide\" data-kid=\"13\">Full Name</label>\n                        <input type=\"text\" id=\"name\" placeholder=\"Sarah Jenkins\" class=\"w-full px-5 py-4 rounded-2xl input-field text-white placeholder:text-white/25\" data-kid=\"14\">\n                    </div>\n                    \n                    <div class=\"space-y-2.5\" data-kid=\"15\">\n                        <label for=\"email\" class=\"text-sm font-semibold text-white/90 ml-1 tracking-wide\" data-kid=\"16\">Work Email</label>\n                        <input type=\"email\" id=\"email\" placeholder=\"sarah@company.io\" class=\"w-full px-5 py-4 rounded-2xl input-field text-white placeholder:text-white/25\" data-kid=\"17\">\n                    </div>\n                    \n                    <div class=\"space-y-2.5 relative\" data-kid=\"18\">\n                        <div class=\"flex justify-between items-center ml-1\" data-kid=\"19\">\n                            <label for=\"password\" class=\"text-sm font-semibold text-white/90 tracking-wide\" data-kid=\"20\">Password</label>\n                            <span class=\"text-[10px] uppercase tracking-widest text-white/30 font-bold\" data-kid=\"21\">Min. 8 characters</span>\n                        </div>\n                        <input type=\"password\" id=\"password\" placeholder=\"••••••••••••\" class=\"w-full px-5 py-4 rounded-2xl input-field text-white placeholder:text-white/25\" data-kid=\"22\">\n                    </div>\n                </div>\n\n                <button type=\"submit\" class=\"w-full py-4.5 rounded-2xl primary-btn text-white font-bold text-lg cursor-pointer active:scale-[0.98] transition-all flex items-center justify-center gap-2 group\" data-kid=\"23\">\n                    Create Workspace\n                    <i class=\"ti ti-arrow-right text-white/50 group-hover:translate-x-1 transition-transform\" data-kid=\"24\"></i>\n                </button>\n            </form>\n\n            \n            <div class=\"space-y-10 pt-4\" data-kid=\"25\">\n                <div class=\"relative\" data-kid=\"26\">\n                    <div class=\"absolute inset-0 flex items-center\" data-kid=\"27\"><div class=\"w-full border-t border-white/10\" data-kid=\"28\"></div></div>\n                    <div class=\"relative flex justify-center text-[10px] uppercase tracking-[0.4em] font-bold\" data-kid=\"29\"><span class=\"bg-[oklch(0.06_0.025_270)] px-6 text-white/30\" data-kid=\"30\">Or join via</span></div>\n                </div>\n\n                <div class=\"grid grid-cols-2 gap-4\" data-kid=\"31\">\n                    <button class=\"flex items-center justify-center gap-3 py-4 px-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all cursor-pointer group\" data-kid=\"32\">\n                        <i class=\"ti ti-brand-google text-white/50 group-hover:text-white transition-colors text-xl\" data-kid=\"33\"></i>\n                        <span class=\"text-sm font-bold text-white/80 group-hover:text-white transition-colors\" data-kid=\"34\">Google</span>\n                    </button>\n                    <button class=\"flex items-center justify-center gap-3 py-4 px-4 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all cursor-pointer group\" data-kid=\"35\">\n                        <i class=\"ti ti-brand-github text-white/50 group-hover:text-white transition-colors text-xl\" data-kid=\"36\"></i>\n                        <span class=\"text-sm font-bold text-white/80 group-hover:text-white transition-colors\" data-kid=\"37\">GitHub</span>\n                    </button>\n                </div>\n            </div>\n\n            \n            <p class=\"text-center text-white/50\" data-kid=\"38\">\n                Already have an account? <a href=\"#\" class=\"text-[#FF500B] hover:text-[#FF6A31] font-bold ml-1 transition-colors\" data-kid=\"39\">Sign in here</a>\n            </p>\n        </div>\n    </section>\n\n    \n    <section class=\"hidden lg:flex w-1/2 relative items-center justify-center overflow-hidden bg-[var(--bg-deep)] border-l border-white/5\" data-kid=\"40\">\n        \n        \n        <div class=\"absolute inset-0 z-0 opacity-40\" data-kid=\"41\">\n            <img src=\"https://images.unsplash.com/photo-1635072523807-48c53963022a?auto=format&w=1200&q=80&fit=crop\" alt=\"Abstract gradient\" class=\"w-full h-full object-cover mix-blend-luminosity\" decoding=\"async\" loading=\"lazy\" data-kid=\"42\">\n        </div>\n\n        \n        <div class=\"absolute inset-0 mesh-gradient pointer-events-none\" data-kid=\"43\">\n            <div class=\"absolute w-[600px] h-[600px] bg-[#FF500B]/15 rounded-full blur-[120px] -top-40 -right-40 animate-pulse\" data-kid=\"44\"></div>\n            <div class=\"absolute w-[500px] h-[500px] bg-purple-600/10 rounded-full blur-[120px] bottom-0 -left-20\" style=\"animation-delay: 1.5s\" data-kid=\"45\"></div>\n        </div>\n\n        \n        <div class=\"relative z-10 w-full max-w-[520px] px-6 space-y-8 animate-float\" data-kid=\"46\">\n            <div class=\"glass-panel p-10 sm:p-14 rounded-[40px] border-white/10 space-y-12\" data-kid=\"47\">\n                \n                <div class=\"inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-[#FF500B]/10 border border-[#FF500B]/20 text-[#FF500B] text-[10px] font-black uppercase tracking-[0.2em]\" data-kid=\"48\">\n                    <span class=\"flex h-2 w-2 relative\" data-kid=\"49\">\n                        <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-[#FF500B] opacity-75\" data-kid=\"50\"></span>\n                        <span class=\"relative inline-flex rounded-full h-2 w-2 bg-[#FF500B]\" data-kid=\"51\"></span>\n                    </span>\n                    System Integrity: Secured\n                </div>\n\n                \n                <h2 class=\"text-5xl font-serif text-white leading-[1.1] italic\" data-kid=\"52\">Unmatched control for <br data-kid=\"53\"> <span class=\"not-italic text-white/40 font-medium\" data-kid=\"54\">modern API stacks.</span></h2>\n\n                \n                <div class=\"space-y-10\" data-kid=\"55\">\n                    \n                    <div class=\"flex items-start gap-6 group\" data-kid=\"56\">\n                        <div class=\"w-14 h-14 shrink-0 rounded-2xl bg-[#FF500B]/10 border border-[#FF500B]/20 flex items-center justify-center group-hover:bg-[#FF500B]/20 transition-all duration-300\" data-kid=\"57\">\n                            <i class=\"ti ti-clock-hour-4 text-[#FF500B] text-3xl\" data-kid=\"58\"></i>\n                        </div>\n                        <div class=\"space-y-1.5\" data-kid=\"59\">\n                            <h3 class=\"text-xl font-bold text-white tracking-tight\" data-kid=\"60\">Sub-5 minute polling</h3>\n                            <p class=\"text-white/40 leading-relaxed text-sm\" data-kid=\"61\">Experience near real-time ingestion. Your dashboard reflects cost spikes before they become crises.</p>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"flex items-start gap-6 group\" data-kid=\"62\">\n                        <div class=\"w-14 h-14 shrink-0 rounded-2xl bg-[#FF500B]/10 border border-[#FF500B]/20 flex items-center justify-center group-hover:bg-[#FF500B]/20 transition-all duration-300\" data-kid=\"63\">\n                            <i class=\"ti ti-shield-lock text-[#FF500B] text-3xl\" data-kid=\"64\"></i>\n                        </div>\n                        <div class=\"space-y-1.5\" data-kid=\"65\">\n                            <h3 class=\"text-xl font-bold text-white tracking-tight\" data-kid=\"66\">AES-256 Encryption</h3>\n                            <p class=\"text-white/40 leading-relaxed text-sm\" data-kid=\"67\">Military-grade vaulting for your sensitive keys. Zero-knowledge architecture by design.</p>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"pt-8 border-t border-white/5 flex items-center justify-between\" data-kid=\"68\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"69\">\n                        <div class=\"flex -space-x-3\" data-kid=\"70\">\n                            <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-9 h-9 rounded-full border-2 border-[oklch(0.06_0.025_270)] object-cover\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"71\">\n                            <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-9 h-9 rounded-full border-2 border-[oklch(0.06_0.025_270)] object-cover\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"72\">\n                            <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-9 h-9 rounded-full border-2 border-[oklch(0.06_0.025_270)] object-cover\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"73\">\n                        </div>\n                        <span class=\"text-[10px] font-bold text-white/30 uppercase tracking-[0.1em]\" data-kid=\"74\">Join 4k+ Developers</span>\n                    </div>\n                    <div class=\"flex gap-1 text-[#FF500B]\" data-kid=\"75\">\n                        <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"76\"></i>\n                        <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"77\"></i>\n                        <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"78\"></i>\n                        <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"79\"></i>\n                        <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"80\"></i>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"absolute -bottom-12 left-1/2 -translate-x-1/2 w-[80%] h-24 bg-[#FF500B]/15 blur-[60px] -z-10\" data-kid=\"81\"></div>\n        </div>\n\n        \n        <div class=\"absolute bottom-12 left-12 right-12 flex justify-between items-end opacity-20 pointer-events-none\" data-kid=\"82\">\n            <div class=\"space-y-2\" data-kid=\"83\">\n                <p class=\"text-[10px] font-mono tracking-widest uppercase\" data-kid=\"84\">FRG_SYS_CORE_v2.1</p>\n                <div class=\"h-px w-24 bg-white/20\" data-kid=\"85\"></div>\n                <p class=\"text-[8px] font-mono leading-tight\" data-kid=\"86\">AUTH_NODE: READY<br data-kid=\"87\">ENCRYPTION: AES-256-GCM<br data-kid=\"88\">REGION: GLOBAL_EDGE</p>\n            </div>\n            <p class=\"text-4xl font-serif italic text-white/50\" data-kid=\"89\">Frugal</p>\n        </div>\n    </section>\n</div>",
