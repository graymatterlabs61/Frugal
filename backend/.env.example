# ─── Database (Neon Postgres) ──────────────────────────────────────────────────
# Get from: console.neon.tech → Connection Details → pooled connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace_with_48_random_bytes_base64url
JWT_EXPIRES_IN_SECONDS=604800

# ─── Encryption (AES-256-GCM for provider API keys at rest) ────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_random_hex

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://getfrugal.dev

# ─── Observability (Sentry) ────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_WELCOME=Frugal <hello@getfrugal.dev>
RESEND_FROM_ALERTS=Frugal Alerts <alerts@getfrugal.dev>
RESEND_FROM_DIGEST=Frugal <digest@getfrugal.dev>
RESEND_FROM_BILLING=Frugal Billing <billing@getfrugal.dev>
RESEND_FROM_NOREPLY=Frugal <noreply@getfrugal.dev>
RESEND_FROM_SUPPORT=Frugal Support <support@getfrugal.dev>
RESEND_FROM_MARKETING=Frugal <hello@getfrugal.dev>

# ─── Upstash QStash (polling cron) ─────────────────────────────────────────────
# Get from: console.upstash.com → QStash
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=eyJ...
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# ─── Upstash Redis (rate limiting + caching) ────────────────────────────────────
# Get from: console.upstash.com → Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Cloudflare R2 (storage) ────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=frugal
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.getfrugal.dev

# ─── Stripe ─────────────────────────────────────────────────────────────────────
# Live: sk_live_xxx | Test: sk_test_xxx — from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxx
# Register webhook at: dashboard.stripe.com → Developers → Webhooks → Add endpoint
# Required events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Create products + recurring prices in Stripe dashboard, then paste the price IDs here
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_PRO=price_xxx
