# ──────────────────────────────────────────────────────────────────────────────
# Frugal — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL (used in Stripe redirect URLs and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server only, bypasses RLS (polling worker, Stripe webhook)
SUPABASE_SERVICE_ROLE_KEY=

# ── Encryption ────────────────────────────────────────────────────────────────
# 64-char hex (32 bytes) for AES-256-GCM API key encryption.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Polling (QStash) ──────────────────────────────────────────────────────────
# Upstash QStash signing keys — verify POST /api/poll requests in production
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Dev fallback shared secret for manual polling (GET /api/poll?secret=…)
POLL_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
# Webhook signing secret (stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe dashboard (Plus tier is "starter" internally)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Optional: Resend Audience for waitlist contacts (secondary durable store).
# Create one at resend.com/audiences and paste its ID here.
RESEND_AUDIENCE_ID=
# From addresses per category — all optional, fall back to getfrugal.dev defaults
# in lib/email/config.ts (domain must be verified in Resend or sends will fail)
RESEND_FROM_WELCOME=Frugal <welcome@getfrugal.dev>
RESEND_FROM_ALERTS=Frugal Alerts <alerts@getfrugal.dev>
RESEND_FROM_BILLING=Frugal Billing <billing@getfrugal.dev>
RESEND_FROM_DIGEST=Frugal Digest <digest@getfrugal.dev>
RESEND_FROM_MARKETING=Frugal <hello@getfrugal.dev>
RESEND_FROM_NOREPLY=Frugal <noreply@getfrugal.dev>
RESEND_FROM_SUPPORT=Frugal Support <support@getfrugal.dev>